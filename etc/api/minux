-- Shared temp-file helper for in-place file edits.
local function rewriteFile(fln, transform)
if fs.exists(fln) == false or fs.isDir(fln) == true then return false end
local parent = fs.getDir(TEMP_EDIT_FILE)
if parent ~= nil and parent ~= "" and fs.exists(parent) == false then
fs.makeDir(parent)
end
local srcfile = fs.open(fln, "r")
local tmpfile = fs.open(TEMP_EDIT_FILE, "w")
local counter = 0
local line = srcfile.readLine()
while line ~= nil do
counter = counter + 1
local out = transform(line, counter)
if out ~= nil then tmpfile.writeLine(out) end
line = srcfile.readLine()
end
srcfile.close()
tmpfile.close()
fs.delete(fln)
fs.move(TEMP_EDIT_FILE, fln)
return true
end

function removeline(fln, linenumber)
expect(1, fln, "string")
expect(2, linenumber, "number")
return rewriteFile(fln, function(line, counter)
if counter == linenumber then return nil end
return line
end)
end

function removestring(fln, target)
expect(1, fln, "string")
expect(2, target, "string")
return rewriteFile(fln, function(line, _)
if line == target then return nil end
return line
end)
end

function replaceline(fln, input, output)
expect(1, fln, "string")
expect(2, input, "string")
expect(3, output, "string")
local replaced = false
local result = rewriteFile(fln, function(line, _)
if line == input then replaced = true return output end
return line
end)
if result == false then return false end
return replaced
end

function insertline(fln, input)
expect(1, fln, "string")
expect(2, input, "string")
if fs.isDir(fln) == true then return false end
if fs.exists(fln) ~= true then return false end
local temp = fs.open(fln, "a")
temp.writeLine(input)
temp.close()
return true
end

function writetable(fln, data)
expect(1, fln, "string")
expect(2, data, "table")
if fs.isDir(fln) == true then return false end
local tempfile = fs.open(fln, "w")
for index = 1, #data do
tempfile.writeLine(data[index])
end
tempfile.close()
return true
end

function readtable(fln)
expect(1, fln, "string")
if fs.exists(fln) == false or fs.isDir(fln) == true then return false end
local tempfile = fs.open(fln, "r")
local data = {}
local line = tempfile.readLine()
while line ~= nil do
table.insert(data, line)
line = tempfile.readLine()
end
tempfile.close()
return data
end

function download(address, filepath)
expect(1, address,  "string")
expect(2, filepath, "string")
if filepath == "" then
minux.debug("http-get:empty target path", "minux")
return false
end
if fs.isDir(filepath) == true then
minux.debug("http-get:target is a directory: " .. filepath, "minux")
return false
end
if minux.hasHttpSupport() ~= true then
minux.debug("http-get:http api unavailable", "minux")
return false
end
local ok, checkErr = http.checkURL(address)
if ok ~= true then
minux.debug("http-get:url rejected: " .. tostring(checkErr or address), "minux")
return false
end
ensureParentDirectory(filepath)
local parent = fs.getDir(filepath)
if parent ~= nil and parent ~= "" and fs.exists(parent) ~= true then
minux.debug("http-get:parent directory missing: " .. parent, "minux")
return false
end
for attempt = 1, 3 do
minux.debug("minux:http-request:" .. address, "minux")
local response, requestErr = http.get(address)
if response ~= nil then
local content = response.readAll()
response.close()
local tempfile = fs.open(filepath, "w")
if tempfile == nil then
minux.debug("http-get:cannot write " .. filepath, "minux")
return false
end
tempfile.write(content)
tempfile.close()
minux.debug("http-get:file retrieved", "minux")
return true
end
minux.debug(
"http-get:failed attempt " .. attempt .. "/3: " .. tostring(requestErr or "unknown"),
"minux"
)
os.sleep(3)
end
minux.debug("http-get:attempt failed", "minux")
return false
end

-- Encryption

function crypt(message, shift)
expect(1, message, "string")
expect(2, shift, "number")
-- Caesar shift over the 26-letter alphabet and the 10 decimal digits.
-- 97 ('a') and 65 ('A') are the ASCII offsets used to map the input byte
-- into the 0..25 range before the modulo, then back to a printable byte.
-- Lua's % operator returns a non-negative remainder for a positive divisor,
-- so negative shifts (used by decrypt) are handled correctly.
local result = {}
for index = 1, #message do
local char = message:sub(index, index)
if char >= "a" and char <= "z" then
char = string.char(((char:byte() - 97 + shift) % 26) + 97)
elseif char >= "A" and char <= "Z" then
char = string.char(((char:byte() - 65 + shift) % 26) + 65)
elseif char >= "0" and char <= "9" then
char = string.char(((char:byte() - 48 + shift) % 10) + 48)
end
result[index] = char
end
return table.concat(result)
end

function encrypt(text, key)
expect(1, text, "string")
expect(2, key, "number")
return minux.crypt(text, key)
end

function decrypt(text, key)
expect(1, text, "string")
expect(2, key, "number")
-- Decryption reverses the Caesar shift by negating the key.
local reverseShift = -key
return minux.crypt(text, reverseShift)
end

-- Table utilities

function tablecontains(cTable, cValue, seekNum)
expect(1, cTable, "table")
expect(2, cValue, "string")
expect(3, seekNum, "number", "nil")
local countNum = 0
if not seekNum then seekNum = 1 end
for key, value in pairs(cTable) do
if value == cValue then
countNum = countNum + 1
if countNum == seekNum then return key end
end
end
return false
end

function tablecount(tbl)
expect(1, tbl, "table")
local size = 0
while tbl[size + 1] ~= nil do
size = size + 1
end
return size
end

