local function resolveColor(name, default)
return COLOR_NAMES[name] or default
end

local function requireAdminOrOwner()
return _G.admin == true or _G.owner == _G.login
end

local function isSystemOwner()
if _G.admin == true then
return true
end
if _G.owner == true then
return true
end
return _G.owner ~= nil and _G.owner ~= false and _G.owner == _G.login
end

local function currentUser()
local user = _G.login
if user == nil or user == false or user == "" or user == NO_USER then
return ROOT_USER
end
return user
end

local function defaultGroupForUser(user)
if user == nil or user == "" or user == ROOT_USER then
return ROOT_GROUP
end
return user
end

-- Read the encryption key from disk. Returns the numeric key, or nil if
-- encryption is not configured.
local function readEncryptKey()
if fs.exists(ENCRYPT_KEY_FILE) then
local keyfile = fs.open(ENCRYPT_KEY_FILE, "r")
local key = tonumber(keyfile.readLine())
keyfile.close()
return key
end
return nil
end

local function ensureDirectory(path)
if path ~= nil and path ~= "" and fs.exists(path) == false then
fs.makeDir(path)
end
end

local function ensureParentDirectory(path)
local parent = fs.getDir(path)
if parent ~= nil and parent ~= "" then
ensureDirectory(parent)
end
end

local function normalisePath(path)
if path == "" then
return ""
end
return fs.combine("", path)
end

local function pathMatchesPrefix(path, prefix)
path = normalisePath(path)
prefix = normalisePath(prefix)
if path == prefix then
return true
end
return string.sub(path, 1, #prefix + 1) == prefix .. "/"
end

local function isHiddenName(name)
return string.sub(name, 1, 1) == "."
end

local function parseModeValue(mode)
if type(mode) == "number" then
if mode < 0 or mode > 777 then
return nil
end
local digits = string.format("%03d", mode)
if string.match(digits, "^[0-7][0-7][0-7]$") == nil then
return nil
end
return tonumber(digits)
elseif type(mode) == "string" then
local digits = string.match(mode, "^0?([0-7][0-7][0-7])$")
if digits == nil then
return nil
end
return tonumber(digits)
end
return nil
end

local function permissionsFromDigit(digit)
return {
read = math.floor(digit / 4) % 2 == 1,
write = math.floor(digit / 2) % 2 == 1,
execute = digit % 2 == 1,
}
end

local function permissionsFromMode(mode)
mode = parseModeValue(mode) or 644
local ownerDigit = math.floor(mode / 100)
local groupDigit = math.floor(mode / 10) % 10
local otherDigit = mode % 10
return {
owner = permissionsFromDigit(ownerDigit),
group = permissionsFromDigit(groupDigit),
other = permissionsFromDigit(otherDigit),
}
end

local function permissionTriplet(bits)
return (bits.read and "r" or "-")
.. (bits.write and "w" or "-")
.. (bits.execute and "x" or "-")
end

local function toModeString(isDir, mode)
local permissions = permissionsFromMode(mode)
return (isDir == true and "d" or "-")
.. permissionTriplet(permissions.owner)
.. permissionTriplet(permissions.group)
.. permissionTriplet(permissions.other)
end

local function encodePermissionEntry(path, entry)
return table.concat({
normalisePath(path),
entry.owner,
entry.group,
string.format("%03d", entry.mode),
}, "\t")
end

local function readPermissionStore()
if permissionStoreCache ~= nil then
return permissionStoreCache
end
local store = {}
if fs.exists(PERMISSIONS_FILE) ~= true then
permissionStoreCache = store
return store
end
local handle = fs.open(PERMISSIONS_FILE, "r")
if handle == nil then
permissionStoreCache = store
return store
end
local line = handle.readLine()
while line ~= nil do
local path, owner, group, mode = string.match(line, "^(.-)\t([^\t]+)\t([^\t]+)\t([0-7][0-7][0-7])$")
if path ~= nil then
store[normalisePath(path)] = {
owner = owner,
group = group,
mode = tonumber(mode),
}
end
line = handle.readLine()
end
handle.close()
permissionStoreCache = store
return store
end

local function writePermissionStore(store)
ensureParentDirectory(PERMISSIONS_FILE)
local paths = {}
for path in pairs(store) do
paths[#paths + 1] = path
end
table.sort(paths)
local handle = fs.open(PERMISSIONS_FILE, "w")
for _, path in ipairs(paths) do
handle.writeLine(encodePermissionEntry(path, store[path]))
end
handle.close()
permissionStoreCache = store
end

local function getPermissionRule(path)
path = normalisePath(path)
for _, rule in ipairs(DEFAULT_PERMISSION_RULES) do
if pathMatchesPrefix(path, rule.prefix) then
return rule
end
end
return nil
end

local function defaultPermissionEntry(path, isDir)
path = normalisePath(path)
local rule = getPermissionRule(path)
if rule ~= nil then
return {
owner = rule.owner or ROOT_USER,
group = rule.group or ROOT_GROUP,
mode = parseModeValue(isDir == true and rule.dirMode or rule.fileMode)
or parseModeValue(isDir == true and rule.fileMode or rule.dirMode)
or (isDir == true and 755 or 644),
}
end
if pathMatchesPrefix(path, "/home/") then
local segments = {}
for segment in string.gmatch(path, "[^/]+") do
segments[#segments + 1] = segment
end
local owner = segments[2] or currentUser()
return {
owner = owner,
group = defaultGroupForUser(owner),
mode = isDir == true and 755 or 644,
}
end
local owner = currentUser()
return {
owner = owner,
group = defaultGroupForUser(owner),
mode = isDir == true and 755 or 644,
}
end

local function permissionEntryFromStore(path, isDir, store)
local entry = store[normalisePath(path)]
if entry ~= nil then
return {
owner = entry.owner,
group = entry.group,
mode = parseModeValue(entry.mode) or (isDir == true and 755 or 644),
}
end
return defaultPermissionEntry(path, isDir)
end

local function permissionEntryForPath(path, isDir)
return permissionEntryFromStore(path, isDir, readPermissionStore())
end

local function setPermissionEntryInStore(path, entry, store)
store[normalisePath(path)] = {
owner = entry.owner,
group = entry.group,
mode = parseModeValue(entry.mode) or 644,
}
return store[normalisePath(path)]
end

local function setPermissionEntry(path, entry)
local store = readPermissionStore()
local result = setPermissionEntryInStore(path, entry, store)
writePermissionStore(store)
return result
end

local function registerPathMetadataInStore(path, isDir, entry, store)
if fs.exists(path) ~= true and entry == nil then
return false
end
local resolved = normalisePath(path)
local metadata = entry or permissionEntryFromStore(resolved, isDir == true, store)
metadata.mode = parseModeValue(metadata.mode) or ((isDir == true) and 755 or 644)
setPermissionEntryInStore(resolved, metadata, store)
return metadata
end

local function registerPathMetadata(path, isDir, entry)
local store = readPermissionStore()
local metadata = registerPathMetadataInStore(path, isDir, entry, store)
if metadata ~= false then
writePermissionStore(store)
end
return metadata
end

local function removePathMetadata(path)
local store = readPermissionStore()
local changed = false
path = normalisePath(path)
for key in pairs(store) do
if pathMatchesPrefix(key, path) then
store[key] = nil
changed = true
end
end
if changed == true then
writePermissionStore(store)
end
return changed
end

local function renamePathMetadata(source, destination)
local store = readPermissionStore()
local updated = {}
local removed = false
source = normalisePath(source)
destination = normalisePath(destination)
for key, entry in pairs(store) do
if pathMatchesPrefix(key, source) then
local suffix = string.sub(key, #source + 1)
updated[destination .. suffix] = {
owner = entry.owner,
group = entry.group,
mode = entry.mode,
}
store[key] = nil
removed = true
end
end
for key, entry in pairs(updated) do
store[key] = entry
end
if removed == true then
writePermissionStore(store)
end
return removed
end

local function principalPermissions(entry)
local permissions = permissionsFromMode(entry.mode)
local user = currentUser()
local group = defaultGroupForUser(user)
if isSystemOwner() == true then
return { read = true, write = true, execute = true }
end
if entry.owner == user then
return permissions.owner
end
if entry.group == group then
return permissions.group
end
return permissions.other
end

local function buildPathInfo(path, depth)
local resolved = normalisePath(path)
if fs.exists(resolved) ~= true then
return nil
end
local isDir = fs.isDir(resolved)
local readOnly = fs.isReadOnly ~= nil and fs.isReadOnly(resolved) or false
local metadata = permissionEntryForPath(resolved, isDir)
local mode = parseModeValue(metadata.mode) or (isDir == true and 755 or 644)
if readOnly == true then
mode = isDir == true and 555 or 444
end
local info = {
path = resolved,
name = fs.getName(resolved),
depth = depth or 0,
isDir = isDir,
type = isDir and "directory" or "file",
readOnly = readOnly,
owner = metadata.owner,
group = metadata.group,
uid = metadata.owner == ROOT_USER and 0 or nil,
gid = metadata.group == ROOT_GROUP and 0 or nil,
modeOctal = mode,
modeOctalString = string.format("%03d", mode),
permissions = permissionsFromMode(mode),
mode = toModeString(isDir, mode),
}
if isDir ~= true then
info.size = fs.getSize(resolved)
end
if fs.getDrive ~= nil then
local ok, drive = pcall(fs.getDrive, resolved)
if ok == true then
info.drive = drive
end
end
if fs.attributes ~= nil then
local ok, attrs = pcall(fs.attributes, resolved)
if ok == true and type(attrs) == "table" then
info.attributes = attrs
info.created = attrs.created
info.modified = attrs.modified
end
end
return info
end

local function sortedChildren(path)
local items = fs.list(path)
table.sort(items, function(left, right)
local leftLower = string.lower(left)
local rightLower = string.lower(right)
if leftLower == rightLower then
return left < right
end
return leftLower < rightLower
end)
return items
end

local function globToLuaPattern(glob)
local pattern = { "^" }
for index = 1, #glob do
local char = string.sub(glob, index, index)
if char == "*" then
table.insert(pattern, ".*")
elseif char == "?" then
table.insert(pattern, ".")
elseif string.match(char, "[%^%$%(%)%%%.%[%]%+%-]") ~= nil then
table.insert(pattern, "%" .. char)
else
table.insert(pattern, char)
end
end
table.insert(pattern, "$")
return table.concat(pattern)
end

local function matchesNeedle(value, needle, caseInsensitive, plain)
if needle == nil then
return true
end
if caseInsensitive == true then
value = string.lower(value)
needle = string.lower(needle)
end
if plain == true then
return string.find(value, needle, 1, true) ~= nil
end
return string.find(value, needle) ~= nil
end

local function matchesEntry(entry, options)
if options.type == "file" and entry.isDir == true then
return false
end
if options.type == "directory" and entry.isDir ~= true then
return false
end
if options.nameContains ~= nil and matchesNeedle(entry.name, options.nameContains, options.caseInsensitive == true, true) ~= true then
return false
end
if options.pathContains ~= nil and matchesNeedle(entry.path, options.pathContains, options.caseInsensitive == true, true) ~= true then
return false
end
if options.namePattern ~= nil then
local pattern = globToLuaPattern(options.namePattern)
local subject = options.caseInsensitive == true and string.lower(entry.name) or entry.name
if string.match(subject, options.caseInsensitive == true and string.lower(pattern) or pattern) == nil then
return false
end
end
return true
end

local function walkEntries(startPath, options, results, depth)
local entry = buildPathInfo(startPath, depth)
if entry == nil then
return
end
local includeRoot = options.includeRoot == true
if entry.isDir ~= true or includeRoot == true or depth > 0 then
if matchesEntry(entry, options) == true then
table.insert(results, entry)
end
end
if entry.isDir ~= true or options.recursive ~= true then
return
end
if options.maxDepth ~= nil and depth >= options.maxDepth then
return
end
for _, childName in ipairs(sortedChildren(entry.path)) do
if options.includeHidden == true or isHiddenName(childName) ~= true then
walkEntries(fs.combine(entry.path, childName), options, results, depth + 1)
end
end
end

local function ensureFile(path, defaultLines)
if fs.exists(path) == true then
return false
end
ensureParentDirectory(path)
local tempfile = fs.open(path, "w")
if defaultLines ~= nil then
for _, line in ipairs(defaultLines) do
tempfile.writeLine(line)
end
end
tempfile.close()
return true
end

local function addAuditFinding(findings, level, message)
table.insert(findings, {
level = level,
message = message,
})
end

local function seedPermissionTree(path, recursive, store)
if fs.exists(path) ~= true then
return
end
registerPathMetadataInStore(path, fs.isDir(path), nil, store)
if recursive == true and fs.isDir(path) == true and minux ~= nil and type(minux.findEntries) == "function" then
local entries = minux.findEntries(path, {
recursive = true,
includeRoot = false,
includeHidden = true,
})
for _, entry in ipairs(entries or {}) do
registerPathMetadataInStore(entry.path, entry.isDir, nil, store)
end
end
end

local function ensurePermissionDefaults()
local created = ensureFile(PERMISSIONS_FILE, {})
if created == true then
permissionStoreCache = nil
end
local store = readPermissionStore()
local recursiveSeed = next(store) == nil
local paths = {
"/boot",
"/boot/autorun.ls",
"/boot/runonce.sh",
"/bin",
"/gbin",
"/etc",
"/etc/apt",
"/etc/api",
"/etc/minux-main",
"/usr/minux-main",
"/usr/minux-main/config",
	"/usr/minux-main/data",
	SERVICE_DISABLED_FILE,
	SERVICES_FILE,
	SETTINGS_FILE,
	ENCRYPT_KEY_FILE,
	AUTH_DIR,
	"/usr/auth-client",
	"/etc/server.sys",
	SERVICE_DEFINITIONS_DIR,
	}
for _, path in ipairs(paths) do
	seedPermissionTree(path, recursiveSeed, store)
end
writePermissionStore(store)
end

