function download(address, filepath)
expect(1, address,  "string")
expect(2, filepath, "string")
if http.checkURL(address) ~= true then
return false
end
for attempt = 1, 3 do
minux.debug("minux:http-request:" .. address, "minux")
local response = http.get(address)
if response ~= nil then
local content = response.readAll()
response.close()
local tempfile = fs.open(filepath, "w")
tempfile.write(content)
tempfile.close()
minux.debug("http-get:file retrieved", "minux")
return true
end
minux.debug("http-get:failed attempt " .. attempt .. "/3", "minux")
os.sleep(3)
end
minux.debug("http-get:attempt failed", "minux")
return false
end

-- Encryption

function crypt(message, shift)
expect(1, message, "string")
expect(2, shift, "number")
-- Caesar shift over the 26-letter alphabet and the 10 decimal digits.
-- 97 ('a') and 65 ('A') are the ASCII offsets used to map the input byte
-- into the 0..25 range before the modulo, then back to a printable byte.
-- Lua's % operator returns a non-negative remainder for a positive divisor,
-- so negative shifts (used by decrypt) are handled correctly.
local result = {}
for index = 1, #message do
local char = message:sub(index, index)
if char >= "a" and char <= "z" then
char = string.char(((char:byte() - 97 + shift) % 26) + 97)
elseif char >= "A" and char <= "Z" then
char = string.char(((char:byte() - 65 + shift) % 26) + 65)
elseif char >= "0" and char <= "9" then
char = string.char(((char:byte() - 48 + shift) % 10) + 48)
end
result[index] = char
end
return table.concat(result)
end

function encrypt(text, key)
expect(1, text, "string")
expect(2, key, "number")
return minux.crypt(text, key)
end

function decrypt(text, key)
expect(1, text, "string")
expect(2, key, "number")
-- Decryption reverses the Caesar shift by negating the key.
local reverseShift = -key
return minux.crypt(text, reverseShift)
end

-- Table utilities

function tablecontains(cTable, cValue, seekNum)
expect(1, cTable, "table")
expect(2, cValue, "string")
expect(3, seekNum, "number", "nil")
local countNum = 0
if not seekNum then seekNum = 1 end
for key, value in pairs(cTable) do
if value == cValue then
countNum = countNum + 1
if countNum == seekNum then return key end
end
end
return false
end

function tablecount(tbl)
expect(1, tbl, "table")
local size = 0
while tbl[size + 1] ~= nil do
size = size + 1
end
return size
end

