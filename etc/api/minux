-- Shared temp-file helper for in-place file edits.
local function rewriteFile(fln, transform)
if fs.exists(fln) == false or fs.isDir(fln) == true then return false end
local parent = fs.getDir(TEMP_EDIT_FILE)
if parent ~= nil and parent ~= "" and fs.exists(parent) == false then
fs.makeDir(parent)
end
local srcfile = fs.open(fln, "r")
local tmpfile = fs.open(TEMP_EDIT_FILE, "w")
local counter = 0
local line = srcfile.readLine()
while line ~= nil do
counter = counter + 1
local out = transform(line, counter)
if out ~= nil then tmpfile.writeLine(out) end
line = srcfile.readLine()
end
srcfile.close()
tmpfile.close()
fs.delete(fln)
fs.move(TEMP_EDIT_FILE, fln)
return true
end

function removeline(fln, linenumber)
expect(1, fln, "string")
expect(2, linenumber, "number")
return rewriteFile(fln, function(line, counter)
if counter == linenumber then return nil end
return line
end)
end

function removestring(fln, target)
expect(1, fln, "string")
expect(2, target, "string")
return rewriteFile(fln, function(line, _)
if line == target then return nil end
return line
end)
end

function replaceline(fln, input, output)
expect(1, fln, "string")
expect(2, input, "string")
expect(3, output, "string")
local replaced = false
local result = rewriteFile(fln, function(line, _)
if line == input then replaced = true return output end
return line
end)
if result == false then return false end
return replaced
end

