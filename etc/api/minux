-- Validate a local username. Returns true when valid, otherwise false and a
-- user-readable error message describing the first failed rule.
function validateUsername(username)
expect(1, username, "string")
if username == "" then
return false, "username is required"
end
if username == NO_USER then
return false, "username is reserved"
end
if #username > 32 then
return false, "username is too long"
end
if string.match(username, USERNAME_PATTERN) == nil then
return false, USERNAME_RULE_TEXT
end
return true
end

local function isPathWithin(path, root)
if path == root then
return true
end
return string.sub(path, 1, #root + 1) == root .. "/"
end

local function nearestExistingAncestor(path)
local candidate = normalisePath(path)
while candidate ~= nil and candidate ~= "" and fs.exists(candidate) ~= true do
local parent = fs.getDir(candidate)
if parent == candidate then
break
end
candidate = parent
end
if candidate == nil or candidate == "" then
candidate = "/"
end
return candidate
end

local function copyMetadataTree(source, destination)
local entries = minux.findEntries(source, {
recursive = true,
includeRoot = true,
includeHidden = true,
})
for _, entry in ipairs(entries or {}) do
local suffix = string.sub(entry.path, #source + 1)
local targetPath = destination .. suffix
registerPathMetadata(targetPath, entry.isDir, {
owner = entry.owner,
group = entry.group,
mode = entry.modeOctal,
})
end
end

function expandPathPattern(pathPattern)
expect(1, pathPattern, "string")
local matches = fs.find(pathPattern)
table.sort(matches)
if #matches == 0 then
return false, "no matching files: " .. pathPattern
end
return matches
end

function makeDirectory(path, allowExisting)
expect(1, path, "string")
expect(2, allowExisting, "boolean", "nil")
path = normalisePath(path)
if path == "" then
return false, "path is required"
end
if fs.exists(path) == true then
if fs.isDir(path) == true and allowExisting == true then
return true
end
if fs.isDir(path) == true then
return false, "directory already exists: " .. path
end
return false, "destination exists: " .. path
end
if fs.isReadOnly(path) == true then
return false, "access denied: " .. path
end
local anchor = nearestExistingAncestor(path)
local permitted, permissionErr = minux.requirePermission(anchor, "write")
if permitted ~= true then
return false, permissionErr
end
local ok, err = pcall(fs.makeDir, path)
if ok ~= true then
return false, tostring(err):gsub("^pcall: ", "")
end
registerPathMetadata(path, true)
return true
end

function copyPath(source, destination)
expect(1, source, "string")
expect(2, destination, "string")
source = normalisePath(source)
destination = normalisePath(destination)
if fs.exists(source) ~= true then
return false, "source does not exist: " .. source
end
if fs.exists(destination) == true then
return false, "destination exists: " .. destination
end
if fs.isReadOnly(destination) == true then
return false, "destination is read-only: " .. destination
end
if fs.isDir(source) == true and isPathWithin(destination, source) == true then
return false, "cannot copy a directory into itself: " .. destination
end
local canRead, readErr = minux.requirePermission(source, "read")
if canRead ~= true then
return false, readErr
end
local parent = fs.getDir(destination)
if parent ~= nil and parent ~= "" and fs.exists(parent) ~= true then
return false, "parent directory does not exist: " .. parent
end
local canWrite, writeErr = minux.requirePermission(destination, "create")
if canWrite ~= true then
return false, writeErr
end
local freeSpace = fs.getFreeSpace(destination)
local size = fs.getSize(source)
if type(freeSpace) == "number" and type(size) == "number" and freeSpace < size then
return false, "not enough space for: " .. destination
end
local ok, err = pcall(fs.copy, source, destination)
if ok ~= true then
return false, tostring(err):gsub("^pcall: ", "")
end
copyMetadataTree(source, destination)
return true
end

function movePath(source, destination)
expect(1, source, "string")
expect(2, destination, "string")
source = normalisePath(source)
destination = normalisePath(destination)
if fs.exists(source) ~= true then
return false, "source does not exist: " .. source
end
if fs.exists(destination) == true then
return false, "destination exists: " .. destination
end
if fs.isReadOnly(destination) == true then
return false, "destination is read-only: " .. destination
end
if fs.isDriveRoot ~= nil and fs.isDriveRoot(source) == true then
return false, "cannot move mount: " .. source
end
if fs.isReadOnly(source) == true then
return false, "cannot move read-only path: " .. source
end
if fs.isDir(source) == true and isPathWithin(destination, source) == true then
return false, "cannot move a directory into itself: " .. destination
end
local canRead, readErr = minux.requirePermission(source, "read")
if canRead ~= true then
return false, readErr
end
local canDelete, deleteErr = minux.requirePermission(source, "delete")
if canDelete ~= true then
return false, deleteErr
end
local parent = fs.getDir(destination)
if parent ~= nil and parent ~= "" and fs.exists(parent) ~= true then
return false, "parent directory does not exist: " .. parent
end
local canCreate, createErr = minux.requirePermission(destination, "create")
if canCreate ~= true then
return false, createErr
end
local ok, err = pcall(fs.move, source, destination)
if ok ~= true then
return false, tostring(err):gsub("^pcall: ", "")
end
renamePathMetadata(source, destination)
return true
end

function deletePath(path, recursive)
expect(1, path, "string")
expect(2, recursive, "boolean", "nil")
path = normalisePath(path)
if fs.exists(path) ~= true then
return false, "path does not exist: " .. path
end
if fs.isDir(path) == true and recursive ~= true then
return false, "is a directory: " .. path
end
if fs.isDriveRoot ~= nil and fs.isDriveRoot(path) == true then
return false, "cannot delete mount: " .. path
end
if fs.isReadOnly(path) == true then
return false, "cannot delete read-only path: " .. path
end
local canDelete, deleteErr = minux.requirePermission(path, "delete")
if canDelete ~= true then
return false, deleteErr
end
local ok, err = pcall(fs.delete, path)
if ok ~= true then
return false, tostring(err):gsub("^pcall: ", "")
end
removePathMetadata(path)
return true
end

