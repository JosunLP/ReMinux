	local services = {}
	local function register(definition)
		if definition.path == nil or fs.exists(definition.path) ~= true then
			return
		end
		services[definition.name] = definition
	end
	register({
		name = "addons",
		trigger = "boot",
		phase = "early",
		order = 20,
		kind = "oneshot",
		path = "/boot/addon.d",
		command = "/boot/addon.d",
		description = "Generated boot addon hook",
	})
	register({
		name = "server",
		trigger = "boot",
		phase = "early",
		order = 10,
		kind = "daemon",
		path = "/etc/server.sys",
		command = "/etc/server.sys",
		description = "Legacy server boot hook",
		stopSupported = false,
	})
	register({
		name = "overrides",
		trigger = "boot",
		phase = "override",
		order = 30,
		kind = "oneshot",
		path = "/boot/override.d",
		command = "/boot/override.d",
		description = "Boot override hook",
	})
	register({
		name = "runonce",
		trigger = "boot",
		phase = "runonce",
		order = 40,
		kind = "runonce",
		path = "/boot/runonce.sh",
		command = "/boot/runonce.sh",
		description = "Boot run-once command list",
	})
	register({
		name = "autorun",
		trigger = "login",
		order = 10,
		kind = "oneshot",
		path = "/boot/autorun.ls",
		command = "/boot/autorun.ls",
