local function serialiseServiceEntry(name, entry)
	return table.concat({
		name,
		entry.state or "inactive",
		entry.updatedAt or "",
		entry.detail or "",
	}, "\t")
end

local function readServiceStateStore()
	local store = {}
	if fs.exists(SERVICES_FILE) ~= true then
		return store
	end
	local handle = fs.open(SERVICES_FILE, "r")
	if handle == nil then
		return store
	end
	local line = handle.readLine()
	while line ~= nil do
		local name, state, updatedAt, detail = string.match(line, "^([^\t]+)\t([^\t]*)\t([^\t]*)\t(.*)$")
		if name ~= nil then
			store[name] = {
				state = state ~= "" and state or "inactive",
				updatedAt = updatedAt ~= "" and updatedAt or nil,
				detail = detail ~= "" and detail or nil,
			}
		end
		line = handle.readLine()
	end
	handle.close()
	return store
end

local function writeServiceStateStore(store)
	local names = {}
	for name in pairs(store) do
		names[#names + 1] = name
	end
	table.sort(names)
	local handle = fs.open(SERVICES_FILE, "w")
	for _, name in ipairs(names) do
		handle.writeLine(serialiseServiceEntry(name, store[name]))
	end
	handle.close()
end

local function timestampString()
	if os.epoch ~= nil then
		return tostring(os.epoch("utc"))
	end
	return tostring(os.time())
end

local function loadServiceDefinitionFile(path)
	local ok, result = pcall(dofile, path)
	if ok ~= true or type(result) ~= "table" then
		return {}
	end
	if result.name ~= nil then
		return { result }
	end
	return result
end

local function collectDeclaredServices()
	local services = {}
	if fs.exists(SERVICE_DEFINITIONS_DIR) == true and fs.isDir(SERVICE_DEFINITIONS_DIR) == true then
		local files = fs.list(SERVICE_DEFINITIONS_DIR)
		table.sort(files)
		for _, file in ipairs(files) do
			local path = fs.combine(SERVICE_DEFINITIONS_DIR, file)
			if fs.isDir(path) ~= true then
				local definitions = loadServiceDefinitionFile(path)
				for _, definition in ipairs(definitions) do
					if type(definition) == "table" and type(definition.name) == "string" and definition.name ~= "" then
						services[definition.name] = definition
					end
				end
			end
		end
	end
	return services
end

