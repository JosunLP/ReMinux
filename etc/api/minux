function getbashcolor()
local colorFile = "/home/" .. _G.login .. "/minux-config/bashcolours.cfg"
local fallback  = "/usr/minux-main/bash/colours.cfg"
local source    = fs.exists(colorFile) and colorFile or fallback
local tempfile  = fs.open(source, "r")
local textName   = tempfile.readLine()
local bgName     = tempfile.readLine()
local promptName = tempfile.readLine()
tempfile.close()
local textColour   = resolveColor(textName,   colors.green)
local bgColour     = resolveColor(bgName,     colors.black)
local promptColour = resolveColor(promptName, colors.red)
return {
textColour, bgColour, promptColour,
textName,   bgName,   promptName,
}
end

