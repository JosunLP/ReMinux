-- minux main api's

-- Internal helpers (not exposed as public API)

local PERIPHERAL_SIDES = { "top", "back", "bottom", "right", "left", "front" }

-- Maps CC color name strings to colors.X values.
local COLOR_NAMES = {
white     = colors.white,     orange    = colors.orange,
magenta   = colors.magenta,   lightBlue = colors.lightBlue,
yellow    = colors.yellow,    lime      = colors.lime,
pink      = colors.pink,      gray      = colors.gray,
lightGray = colors.lightGray, cyan      = colors.cyan,
purple    = colors.purple,    blue      = colors.blue,
brown     = colors.brown,     green     = colors.green,
red       = colors.red,       black     = colors.black,
}

local NO_USER = "foo"
local SETTINGS_FILE = "/usr/minux-main/settings.cfg"
local ENCRYPT_KEY_FILE = "/usr/minux-main/config/encr.conf"
local AUTH_DIR = "/usr/local/auth/"
local TEMP_EDIT_FILE = "/temp/dev/removeline.tmp"

local function resolveColor(name, default)
return COLOR_NAMES[name] or default
end

local function requireAdminOrOwner()
return _G.admin == true or _G.owner == _G.login
end

-- Read the encryption key from disk. Returns the numeric key, or nil if
-- encryption is not configured.
local function readEncryptKey()
if fs.exists(ENCRYPT_KEY_FILE) then
local keyfile = fs.open(ENCRYPT_KEY_FILE, "r")
local key = tonumber(keyfile.readLine())
keyfile.close()
return key
end
return nil
end

-- Write a single key=value line in a config file, replacing any existing entry.
local function updateConfigLine(cfgf, key, value)
local line = minux.findline(cfgf, key .. "=")
if line ~= false and line ~= nil then
minux.removeline(cfgf, line)
end
minux.insertline(cfgf, key .. "=" .. value)
end

-- Resolve the settings file path for the current user (falls back to global).
local function resolveSettingsFile()
local cfgf = SETTINGS_FILE
if _G.login ~= nil and _G.login ~= NO_USER then
local userCfg = "/home/" .. _G.login .. "/minux-config/minux.cfg"
if fs.exists(userCfg) then
cfgf = userCfg
end
end
return cfgf
end

-- Ensure the per-user config directory and file exist, creating them with
-- default content when missing.
local function ensureUserConfig(defaults)
if _G.login == nil or _G.login == "foo" then
return SETTINGS_FILE
end
local dir = "/home/" .. _G.login .. "/minux-config/"
local cfgf = dir .. "minux.cfg"
if fs.exists(cfgf) == false then
fs.makeDir(dir)
local tempfile = fs.open(cfgf, "w")
for _, line in ipairs(defaults) do
tempfile.writeLine(line)
end
tempfile.close()
end
return cfgf
end

-- Apply the common "login granted" finalisation: set global credentials, run
-- the autorun script, and optionally clear the screen.
local function finalizeLogin(username, password, grantAdmin)
_G.login = username
_G.masterpass = password
_G.validlogin = true
if grantAdmin == true then
_G.admin = true
end
shell.run("/boot/autorun.ls")
if minux.getconfig("clearlogin") == "enabled" then
term.setCursorPos(1, 1)
term.clear()
end
return true
end

-- Recursive file listing helpers

function lsr(ptn)
expect(1, ptn, "string")
if fs.exists(ptn) == false then return false end
if fs.isDir(ptn) == false then return false end
if fs.exists("/temp/ls") == false then fs.makeDir("/temp/ls") end
if fs.exists("/temp/ls/files.ls") then fs.delete("/temp/ls/files.ls") end
if fs.exists("/temp/ls/todo") then fs.delete("/temp/ls/todo") end
fs.makeDir("/temp/ls/todo")
local lsfc = 0
minux.list(ptn, lsfc)
local tdff = "start"
while tdff ~= nil and fs.exists("/temp/ls/todo/") do
local todofolderlist = fs.list("/temp/ls/todo/")
tdff = todofolderlist[1]
if tdff ~= nil then
if fs.exists("/temp/ls/todo/" .. tdff) then
local todofile = fs.open("/temp/ls/todo/" .. tdff, "r")
local line = todofile.readLine()
while line ~= nil do
minux.list(line, lsfc)
line = todofile.readLine()
end
todofile.close()
fs.delete("/temp/ls/todo/" .. tdff)
end
else
tdff = nil
end
lsfc = lsfc + 1
end
return minux.readtable("/temp/ls/files.ls")
end

function list(ptn, lsfc)
expect(1, ptn, "string")
expect(2, lsfc, "number")
local tempfile = fs.list(ptn)
local fls = fs.open("/temp/ls/files.ls", "a")
for index = 1, #tempfile do
local fln = tempfile[index]
if fs.isDir(ptn .. fln) then
local folderfile = fs.open("/temp/ls/todo/" .. lsfc .. ".ls", "a")
folderfile.writeLine(ptn .. fln .. "/")
folderfile.close()
elseif fs.exists(ptn .. fln) then
fls.writeLine(ptn .. fln)
end
end
fls.close()
return tempfile
end

function lsa(ptn)
expect(1, ptn, "string")
local tempfile = fs.list(ptn)
local fls = fs.open("/temp/ls/a.ls", "w")
for index = 1, #tempfile do
local fln = tempfile[index]
if fs.isDir(ptn .. fln) then
fls.writeLine("DIR:" .. ptn .. fln)
elseif fs.exists(ptn .. fln) then
fls.writeLine("File:" .. ptn .. fln .. " " .. fs.getSize(ptn .. fln) .. "b")
end
end
fls.writeLine("Free space:" .. fs.getFreeSpace(ptn) .. " bytes")
fls.close()
return minux.readtable("/temp/ls/a.ls")
end

-- Authentication

function logintype()
return minux.getconfig("login")
end

function login(username, password)
expect(1, username, "string")
expect(2, password, "string")
local authtype = logintype()

-- Preserve existing session so it can be restored on failure.
local wasvalid = false
local savedAdmin, savedLogin, savedPass
if _G.validlogin == true then
minux.debug("login:valid login detected", "minux")
wasvalid = true
savedAdmin = _G.admin
savedLogin = _G.login
savedPass  = _G.masterpass
end
_G.admin      = false
_G.login      = false
_G.masterpass = false
_G.validlogin = false

if authtype == "local" then
minux.debug("login:local", "minux")
local key = readEncryptKey()
if key ~= nil then
minux.debug("login:Encrypt enabled, reading key..", "minux")
else
minux.debug("login:Encrypt disabled", "minux")
end
minux.debug("login: searching user file", "minux")
local userFile = AUTH_DIR .. username .. ".usr"
if fs.exists(userFile) then
minux.debug("login:u-" .. username, "minux")
local file = fs.open(userFile, "r")
local storedPass = file.readLine()
file.close()
if key ~= nil then
storedPass = minux.decrypt(storedPass, key)
end
minux.debug("login:reading user file", "minux")
if password == storedPass then
minux.debug("login:granted:U-" .. username, "login")
local isRoot = (username == "root")
if isRoot then
_G.owner = true
minux.debug("login:admin", "login")
end
return finalizeLogin(username, password, isRoot)
else
minux.debug("login:denied:U-" .. username, "login")
minux.debug("login:denied", "minux")
end
else
minux.debug("login:noexist:U-" .. username, "minux")
end

elseif authtype == "network" then
minux.debug("Nlogin:starting", "login")
if _G.server == nil or _G.server == "[none]" then
minux.debug("nlogin:searching dhcp", "minux")
os.run({}, "/boot/network/dhcp.sys")
end
if _G.server == nil or _G.server == "[none]" then
minux.debug("login:E:204:DHCP not found", "minux")
sleep(5)
end

rednet.send(_G.server, "AUTH-ID")
minux.debug("login:AUTH-REQ-" .. _G.server, "minux")
local tempauth = nil
for attempt = 1, 3 do
local sender, data = rednet.receive(1)
minux.debug("login:request count:" .. attempt, "minux")
if sender == _G.server then
minux.debug("login:DHCP-reply", "minux")
if data == "AUTH-NOEXIST" then
minux.debug("login:E:205:noauth", "minux")
elseif data == nil or data == "" then
minux.debug("login:E:206:Data nil error", "minux")
else
tempauth = tonumber(data)
minux.debug("login:auth-server:" .. tempauth, "minux")
end
break
end
end
if tempauth == nil then
minux.debug("nlogin:E:209", "minux")
end

minux.debug("login:checking for ownership", "minux")
_G.owner      = false
_G.ownergroup = false
if fs.exists("/usr/auth-client/owner.cfg") then
minux.debug("login:owner file found, running check", "minux")
auth.checkowner()
else
minux.debug("login:no owner file", "minux")
end

minux.debug("login:initiating login", "minux")
rednet.send(tempauth, "AUTH-LOGIN")
local sender, data = rednet.receive(1)
if sender == tempauth then
if data == "AUTH-ACK" then
minux.debug("login:auth-ack", "minux")
_G.authserver = tempauth
else
minux.debug("login:E:207:auth-reply-noack", "minux")
end
else
minux.debug("login:E:208:auth-noreply", "minux")
end
if _G.authserver == nil or _G.authserver == "" then
minux.debug("login:E:209:auth connect error", "minux")
end

minux.debug("login:auth:" .. _G.authserver, "minux")
minux.debug("building netlib table", "minux")
local sendtable = { username, password }
minux.debug("login:u-" .. sendtable[1], "minux")
local reply = netlib.sendtable(_G.authserver, sendtable)
if reply == true then
minux.debug("login:data Sync success", "minux")
else
minux.debug("login:E:210:data sync error", "minux")
return false
end

local response = netlib.getstring(_G.authserver, 1)
minux.debug("login:processing response", "minux")
if response == "accept" then
minux.debug("login:credentials accepted", "minux")
if _G.owner ~= false then
if _G.owner == username then
minux.debug("login:user=owner:ADMIN granted:" .. username, "login")
return finalizeLogin(username, password, true)
elseif _G.ownergroup ~= false then
minux.debug("login:groupname=true", "minux")
auth.checkgroup(_G.ownergroup, username)
if _G.isgroupmember == true then
minux.debug("login:user=groupmember:USER granted:" .. username, "login")
return finalizeLogin(username, password, false)
else
minux.debug("login:auth-denied:" .. username, "login")
minux.debug("login:user~=groupmember:denied", "minux")
end
end
else
minux.debug("login:nogroup:USER granted:" .. username, "login")
return finalizeLogin(username, password, false)
end
elseif response == "admin" then
minux.debug("login:granted-admin:" .. username, "login")
return finalizeLogin(username, password, true)
else
minux.debug("login:denied", "login")
end

if _G.admin == true then
minux.debug("login:ADMIN:" .. username, "minux")
return finalizeLogin(username, password, true)
elseif _G.validlogin == true then
minux.debug("login:USER:" .. username, "minux")
return finalizeLogin(username, password, false)
else
minux.debug("login:DENIED:" .. username, "minux")
end
end

-- Restore the previous session if login failed.
if wasvalid == true then
_G.admin      = savedAdmin
_G.login      = savedLogin
_G.masterpass = savedPass
end
return false
end

function checkuser(username, password)
expect(1, username, "string")
expect(2, password, "string")
minux.debug("checkuser:starting")
-- Save and restore the caller's session.
local saved = {
login      = _G.login,
masterpass = _G.masterpass,
admin      = _G.admin,
validlogin = _G.validlogin,
owner      = _G.owner,
}
local loginResult = minux.login(username, password)
if loginResult == false then
minux.debug("login denied")
return false
end
minux.debug("checkuser:building return table")
local returntable = {
_G.login, _G.masterpass, _G.admin, _G.validlogin, _G.owner,
}
minux.debug("checkuser:resetting credentials")
_G.login      = saved.login
_G.masterpass = saved.masterpass
_G.admin      = saved.admin
_G.validlogin = saved.validlogin
_G.owner      = saved.owner
return returntable
end

function lock()
if logintype() ~= "disabled" then
term.clear()
term.setCursorPos(1, 1)
print("Minux V:" .. _G.version)
print(" ")
print("This system is currently locked by user:" .. _G.login)
print("Type the password to unlock this system")
print("If you already unlocked it, hit Enter")
print(" ")
_G.lockactive = true
while _G.lockactive == true do
write("password:")
local input = read("*")
if _G.lockactive == false then return 0 end
local key = readEncryptKey()
local expected = _G.masterpass
if key ~= nil then
expected = minux.decrypt(_G.masterpass, key)
end
if input == expected then
_G.lockactive = false
else
print("Wrong password")
end
end
else
print("Cannot enable lock with users disabled")
print("Hit Enter to continue")
read()
end
end

function sanitycheck()
apt.verifyconfig()
local cfl = SETTINGS_FILE
if fs.exists(cfl) == false then
minux.debug("generating settings file", "minux")
local tempfile = fs.open(cfl, "w")
tempfile.writeLine("login=disabled")
tempfile.close()
end
-- Ensure all required keys exist.
local defaults = {
{ "network=",      "network=disabled" },
{ "login=",        "login=disabled" },
{ "debug=",        "debug=disabled" },
{ "mapcleanup=",   "mapcleanup=enabled" },
{ "welcome=",      "welcome=enabled" },
{ "update=",       "update=disabled" },
{ "crashhandler=", "crashhandler=enabled" },
}
for _, entry in ipairs(defaults) do
if minux.findline(cfl, entry[1]) == false then
minux.insertline(cfl, entry[2])
end
end
if minux.findline(cfl, "ui=") == false then
local uiDefault = "workspace"
if minux.findline("/etc/apt/list/installed", "menu") ~= false then
uiDefault = "menu"
end
minux.insertline(cfl, "ui=" .. uiDefault)
end
if minux.getconfig("ui") == "menu" and minux.findline("/etc/apt/list/installed.db", "menu") == false then
minux.setconfig("ui", "workspace")
end
if logintype() == "network" and auth == nil then
minux.setconfig("login", "local")
minux.debug("Warning:no auth: setting login to local", "warning")
end
if logintype() == "network" and netlib == nil then
minux.setconfig("login", "local")
minux.debug("Warning:no netlib: setting login to local", "warning")
end
if turtle == true and minux.getconfig("welcome") == "enabled" then
minux.setconfig("welcome", "disabled")
end
if _G.version == "Cleaninstall" then
minux.download("https://minux.cc/apt/2.0/os/manifest/minux-main.db", "/etc/apt/list/minux-main.db")
end
if _G.version == "Cleaninstall" or _G.version == "Unknown" then
apt.rebuildgenerated()
end
if minux.logintype() == "network" and minux.getconfig("network") ~= "enabled" then
minux.setconfig("network", "enabled")
minux.debug("Warning:network disabled: setting to enabled", "warning")
end
local authtype = minux.getconfig("login")
while fs.exists(AUTH_DIR .. "root.usr") == false and authtype == "local" do
term.clear()
term.setCursorPos(1, 1)
minux.debug("login:E:201:no root user", "minux")
print("root account does not exist")
print("Creating root user:")
print(" ")
write("please enter the root password:")
local newpass = read("*")
write("please re-enter the root password:")
local newpass2 = read("*")
if newpass ~= "" and newpass == newpass2 then
minux.debug("login:creating user", "minux")
local key = readEncryptKey()
if key ~= nil then
newpass = minux.encrypt(newpass, key)
end
local file = fs.open(AUTH_DIR .. "root.usr", "w")
file.write(newpass)
file.close()
minux.debug("login:root account created.", "minux")
else
minux.debug("login:rootcreate:invalid data", "minux")
print("invalid data, try again")
sleep(1)
end
end
end

function perfind(peripheralType)
expect(1, peripheralType, "string")
for _, side in ipairs(PERIPHERAL_SIDES) do
if peripheral.getType(side) == peripheralType then
return side
end
end
return "NONE"
end

function monitorprint(printstring)
expect(1, printstring, "string", "number")
if _G.monitorside == "NONE" then return false end
if printstring == nil or printstring == "" then return false end
local oldTerm = term.redirect(_G.monitor)
print(printstring)
term.redirect(oldTerm)
return true
end

-- Config read/write

function getconfig(value)
expect(1, value, "string")
local cfgf = SETTINGS_FILE

if value == "login" then
if minux.findline(cfgf, "login=local") then return "local"
elseif minux.findline(cfgf, "login=network") then return "network"
else return "disabled" end
elseif value == "encrypt" then
return fs.exists(ENCRYPT_KEY_FILE) == true
elseif value == "crashhandler" then
if minux.findline(cfgf, "crashhandler=disabled") then return "disabled"
else return "enabled" end
elseif value == "clearlogin" then
if minux.findline(cfgf, "clearlogin=disabled") then return "disabled"
else return "enabled" end
elseif value == "network" then
if minux.findline(cfgf, "network=enabled") then return "enabled"
else return "disabled" end
elseif value == "mapcleanup" then
if minux.findline(cfgf, "mapcleanup=enabled") then return "enabled"
else return "disabled" end
elseif value == "ui" then
local settingsfile = resolveSettingsFile()
if minux.findline(settingsfile, "ui=prompt")   then return "prompt"
elseif minux.findline(settingsfile, "ui=craftos")  then return "craftos"
elseif minux.findline(settingsfile, "ui=menu")     then return "menu"
else return "workspace" end
elseif value == "debug" then
if     minux.findline(cfgf, "debug=enabled")  then return "enabled"
elseif minux.findline(cfgf, "debug=logging")  then return "logging"
elseif minux.findline(cfgf, "debug=full")     then return "full"
else return "disabled" end
elseif value == "update" then
if     minux.findline(cfgf, "update=enabled") then return "enabled"
elseif minux.findline(cfgf, "update=always")  then return "always"
else return "disabled" end
elseif value == "welcome" then
local settingsfile = resolveSettingsFile()
if minux.findline(settingsfile, "welcome=enabled") then return "enabled"
else return "disabled" end
else
return false
end
end

function setconfig(config, setting)
expect(1, config, "string")
expect(2, setting, "string")
local cfgf = SETTINGS_FILE

-- Options that require admin or owner rights.
local adminOnlyOptions = {
login = true, encrypt = true, crashhandler = true,
network = true, debug = true,
}
if adminOnlyOptions[config] == true and not requireAdminOrOwner() then
minux.debug("config:denied! not admin or owner", "login")
return false
end

if config == "login" then
if setting ~= "local" and setting ~= "network" and setting ~= "disabled" then
minux.debug("config:login-invalid setting", "minux")
return false
end
minux.debug("config:option:login", "minux")
updateConfigLine(cfgf, "login", setting)
minux.debug("config:login:" .. setting, "minux")
if setting == "network" then
if auth == nil then apt.install("auth-client") end
if netlib == nil then apt.install("netlib") end
minux.setconfig("network", "enabled")
end
return true

elseif config == "encrypt" then
if setting ~= "enabled" and setting ~= "disabled" then
minux.debug("config:invalid input", "minux")
return false
end
local currentlyEncrypted = minux.getconfig("encrypt")
if setting == "enabled" then
if currentlyEncrypted == true then
minux.debug("config:already enabled", "minux")
return false
end
minux.debug("generating key", "minux")
local key = os.getComputerID() * 3
local keyfile = fs.open(ENCRYPT_KEY_FILE, "w")
keyfile.writeLine(key)
keyfile.close()
minux.debug("config:encrypting user files", "minux")
os.run({}, "/etc/minux-main/sys/ecpw.sys")
return true
else
if currentlyEncrypted ~= true then
minux.debug("config:already disabled", "minux")
return false
end
minux.debug("config:decrypting user files", "minux")
os.run({}, "/etc/minux-main/sys/dcpw.sys")
minux.debug("removing key", "minux")
fs.delete(ENCRYPT_KEY_FILE)
return true
end

elseif config == "crashhandler" then
if setting ~= "disabled" and setting ~= "enabled" then
minux.debug("config:crashhandler-invalid setting", "minux")
return false
end
minux.debug("config:option:crashhandler", "minux")
updateConfigLine(cfgf, "crashhandler", setting)
minux.debug("config:crashhandler:" .. setting, "minux")
return true

elseif config == "clearlogin" then
if setting ~= "disabled" and setting ~= "enabled" then
minux.debug("config:clearlogin-invalid setting", "minux")
return false
end
minux.debug("config:option:clearlogin", "minux")
updateConfigLine(cfgf, "clearlogin", setting)
minux.debug("config:clearlogin:" .. setting, "minux")
return true

elseif config == "network" then
if setting ~= "disabled" and setting ~= "enabled" then
minux.debug("config:network-invalid setting", "minux")
return false
end
minux.debug("config:option:network", "minux")
updateConfigLine(cfgf, "network", setting)
minux.debug("config:network:" .. setting, "minux")
return true

elseif config == "update" then
if setting ~= "always" and setting ~= "enabled" and setting ~= "disabled" then
minux.debug("config:update-invalid setting", "minux")
return false
end
minux.debug("config:option:update", "minux")
updateConfigLine(cfgf, "update", setting)
minux.debug("config:update:" .. setting, "minux")
return true

elseif config == "mapcleanup" then
if setting ~= "enabled" and setting ~= "disabled" then
minux.debug("config:mapcleanup-invalid setting", "minux")
return false
end
minux.debug("config:option:mapcleanup", "minux")
updateConfigLine(cfgf, "mapcleanup", setting)
minux.debug("config:mapcleanup:" .. setting, "minux")
return true

elseif config == "welcome" then
if setting ~= "enabled" and setting ~= "disabled" then
minux.debug("config:welcome-invalid setting", "minux")
return false
end
minux.debug("config:option:welcome", "minux")
local settingsfile = ensureUserConfig({ "welcome=" .. setting, "ui=menu" })
updateConfigLine(settingsfile, "welcome", setting)
minux.debug("config:welcome:" .. setting, "minux")
return true

elseif config == "menu" or config == "ui" then
if setting ~= "prompt" and setting ~= "menu" and setting ~= "workspace" and setting ~= "craftos" then
minux.debug("config:menu-invalid input", "minux")
return false
end
minux.debug("config:option:menu", "minux")
local settingsfile = ensureUserConfig({ "ui=" .. setting, "welcome=enabled" })
updateConfigLine(settingsfile, "ui", setting)
minux.debug("config:ui:" .. setting, "minux")
return true

elseif config == "debug" then
if setting ~= "enabled" and setting ~= "disabled" and setting ~= "logging" and setting ~= "full" then
minux.debug("config:debug-invalid setting", "minux")
return false
end
minux.debug("config:option:debug", "minux")
updateConfigLine(cfgf, "debug", setting)
_G.debugmode = setting
minux.debug("config:setting:" .. setting, "minux")
return true

else
minux.debug("config: invalid input", "minux")
return false
end
end

-- Color helpers

function testcolor()
local colorFile = "/home/" .. _G.login .. "/minux-config/bashcolours.cfg"
if fs.exists(colorFile) == false then
local defaults = {
colors.green, colors.black, colors.red,
"green",      "black",      "red",
}
fs.makeDir("/home/" .. _G.login .. "/minux-config/")
minux.writetable(colorFile, defaults)
end
local colordata = minux.getbashcolor()
if colordata[1] == colordata[2] then
minux.debug("Prompt and bg color are identical, changing bgcolor", "minux")
if colordata[4] ~= "black" then
colordata[5] = "black"
else
colordata[5] = "white"
end
minux.bashcolor(colordata[4], colordata[5], colordata[6])
end
end

function bashcolor(textcolor, backgroundcolor, promptcolor)
expect(1, textcolor,       "string", "nil")
expect(2, backgroundcolor, "string", "nil")
expect(3, promptcolor,     "string", "nil")
if textcolor       == nil then textcolor       = "white"  end
if backgroundcolor == nil then backgroundcolor = "black"  end
if promptcolor     == nil then promptcolor     = "yellow" end
