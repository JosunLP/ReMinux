local function readDisabledServices()
	local disabled = {}
	local lines = minux.readtable(SERVICE_DISABLED_FILE)
	if type(lines) ~= "table" then
		return disabled
	end
	for _, name in ipairs(lines) do
		disabled[name] = true
	end
	return disabled
end

local function mergeServiceDefinitions()
	local services = collectLegacyServices()
	for name, definition in pairs(collectDeclaredServices()) do
		services[name] = definition
	end
	return services
end

local function buildServiceRecord(name, definition)
	local state = readServiceStateStore()[name] or {}
	local disabled = readDisabledServices()
	local record = {}
	for key, value in pairs(definition) do
		record[key] = value
	end
	record.name = name
	record.enabled = disabled[name] ~= true
	record.state = state.state or "inactive"
	record.detail = state.detail
	record.updatedAt = state.updatedAt
	record.trigger = record.trigger or "manual"
	record.order = tonumber(record.order) or DEFAULT_SERVICE_ORDER
	record.kind = record.kind or "oneshot"
	return record
end

local function serviceSessionState()
	if type(_G.__minuxServicesStarted) ~= "table" then
		_G.__minuxServicesStarted = {}
	end
	return _G.__minuxServicesStarted
end

-- Write a single key=value line in a config file, replacing any existing entry.
local function updateConfigLine(cfgf, key, value)
local line = minux.findline(cfgf, key .. "=")
if line ~= false and line ~= nil then
minux.removeline(cfgf, line)
end
minux.insertline(cfgf, key .. "=" .. value)
end

-- Resolve the settings file path for the current user (falls back to global).
local function resolveSettingsFile()
local cfgf = SETTINGS_FILE
if _G.login ~= nil and _G.login ~= NO_USER then
local userCfg = "/home/" .. _G.login .. "/minux-config/minux.cfg"
if fs.exists(userCfg) then
cfgf = userCfg
end
end
return cfgf
end

-- Ensure the per-user config directory and file exist, creating them with
-- default content when missing.
local function ensureUserConfig(defaults)
if _G.login == nil or _G.login == "foo" then
return SETTINGS_FILE
end
local dir = "/home/" .. _G.login .. "/minux-config/"
local cfgf = dir .. "minux.cfg"
if fs.exists(cfgf) == false then
fs.makeDir(dir)
local tempfile = fs.open(cfgf, "w")
for _, line in ipairs(defaults) do
tempfile.writeLine(line)
end
tempfile.close()
end
	return cfgf
end

function setServiceState(name, state, detail)
	expect(1, name, "string")
	expect(2, state, "string")
	expect(3, detail, "string", "nil")
	local store = readServiceStateStore()
	store[name] = {
		state = state,
		detail = detail,
		updatedAt = timestampString(),
	}
	writeServiceStateStore(store)
	return true
end

function getService(name)
	expect(1, name, "string")
	local definitions = mergeServiceDefinitions()
	local definition = definitions[name]
	if definition == nil then
		return nil
	end
	return buildServiceRecord(name, definition)
end

function listServices(trigger)
	expect(1, trigger, "string", "nil")
	local definitions = mergeServiceDefinitions()
	local services = {}
	for name, definition in pairs(definitions) do
		if trigger == nil or definition.trigger == trigger then
			services[#services + 1] = buildServiceRecord(name, definition)
		end
	end
	table.sort(services, function(left, right)
		if left.order == right.order then
			return left.name < right.name
		end
		return left.order < right.order
	end)
	return services
end

function setServiceEnabled(name, enabled)
	expect(1, name, "string")
	expect(2, enabled, "boolean")
	local service = minux.getService(name)
	if service == nil then
		return false, "unknown service: " .. name
	end
	local disabledNames = {}
	local disabledLookup = readDisabledServices()
	for existing in pairs(disabledLookup) do
		if existing ~= name then
			disabledNames[#disabledNames + 1] = existing
		end
	end
	if enabled ~= true then
		disabledNames[#disabledNames + 1] = name
		minux.setServiceState(name, "disabled", "disabled by service command")
	else
		local state = minux.getService(name)
		if state ~= nil and state.state == "disabled" then
			minux.setServiceState(name, "inactive", "enabled")
		end
	end
	table.sort(disabledNames)
	minux.writetable(SERVICE_DISABLED_FILE, disabledNames)
	return true
end

local function runRunOnceService(path)
	local commands = minux.readtable(path)
	if type(commands) ~= "table" then
		return true
	end
	for _, command in ipairs(commands) do
		if command ~= nil and command ~= "" then
			local ok = shell.run(command)
			if ok ~= true then
				return false, "command failed: " .. command
			end
		end
	end
	minux.writetable(path, {})
	return true
end

function startService(name, options)
	expect(1, name, "string")
	expect(2, options, "table", "nil")
	local service = minux.getService(name)
	if service == nil then
		return false, "unknown service: " .. name
	end
	local runOptions = options or {}
	if service.enabled ~= true and runOptions.ignoreDisabled ~= true then
		return false, "service is disabled: " .. name
	end
	local startedServices = serviceSessionState()
	if runOptions.oncePerSession == true and runOptions.force ~= true and startedServices[name] == true then
		return true
	end
	minux.setServiceState(name, "starting", service.description)
	local ok, err
	if service.kind == "runonce" then
		ok, err = runRunOnceService(service.command)
	elseif service.kind == "daemon" then
		minux.safeOpenTab(service.command)
		ok = true
	else
		ok = shell.run(service.command)
		if ok ~= true then
			err = "command failed: " .. service.command
		end
	end
	if ok == true then
		local completedState = service.kind == "daemon" and "running" or "completed"
		minux.setServiceState(name, completedState, service.command)
		startedServices[name] = true
		return true
	end
	minux.setServiceState(name, "failed", err)
	return false, err
end

function stopService(name)
	expect(1, name, "string")
	local service = minux.getService(name)
	if service == nil then
		return false, "unknown service: " .. name
	end
	if service.stopCommand ~= nil and service.stopCommand ~= "" then
		local ok = shell.run(service.stopCommand)
		if ok ~= true then
			minux.setServiceState(name, "failed", "stop failed")
			return false, "stop command failed: " .. service.stopCommand
		end
		minux.setServiceState(name, "stopped", service.stopCommand)
		return true
	end
	if service.kind == "daemon" then
		return false, "service does not support stop in this environment"
	end
	minux.setServiceState(name, "stopped", "stopped")
	return true
end

function restartService(name)
	expect(1, name, "string")
	local stopped, stopErr = minux.stopService(name)
	if stopped ~= true and stopErr ~= nil and string.find(stopErr, "does not support stop", 1, true) ~= nil then
		return false, stopErr
	end
	return minux.startService(name, {
		force = true,
	})
end

function runServiceTrigger(trigger, phase)
	expect(1, trigger, "string")
	expect(2, phase, "string", "nil")
	local services = minux.listServices(trigger)
	for _, service in ipairs(services) do
		if phase == nil or service.phase == phase then
		if service.enabled == true then
			local ok, err = minux.startService(service.name, {
				ignoreDisabled = true,
				oncePerSession = trigger == "boot",
			})
			if ok ~= true then
				return false, err
			end
		else
			minux.setServiceState(service.name, "disabled", "disabled")
		end
		end
	end
	return true
end

-- Apply the common "login granted" finalisation: set global credentials, run
-- the autorun script, and optionally clear the screen.
local function finalizeLogin(username, password, grantAdmin)
	_G.login = username
	_G.masterpass = password
_G.validlogin = true
	if grantAdmin == true then
		_G.admin = true
	end
	minux.runServiceTrigger("login")
	if minux.getconfig("clearlogin") == "enabled" then
		term.setCursorPos(1, 1)
		term.clear()
end
return true
end

-- Recursive file listing helpers

function getIoContext()
return ioContextStack[#ioContextStack]
end

function pushIoContext(context)
expect(1, context, "table", "nil")
local resolved = context or {}
table.insert(ioContextStack, resolved)
return resolved
end

function popIoContext()
if #ioContextStack == 0 then
return nil
end
local context = ioContextStack[#ioContextStack]
ioContextStack[#ioContextStack] = nil
return context
end

function withIoContext(context, callback, ...)
expect(1, context, "table", "nil")
expect(2, callback, "function")
pushIoContext(context or {})
local results = table.pack(pcall(callback, ...))
popIoContext()
if results[1] ~= true then
error(results[2], 0)
end
return table.unpack(results, 2, results.n)
end

function readInputLines()
local context = getIoContext()
if type(context) ~= "table" then
return nil
end
if type(context.readLines) == "function" then
return context.readLines()
end
if type(context.inputLines) == "table" then
return context.inputLines
end
return nil
end

function writeOutputLine(line)
expect(1, line, "string")
local context = getIoContext()
if type(context) == "table" then
if type(context.writeLine) == "function" then
context.writeLine(line)
return true
end
if type(context.outputLines) == "table" then
table.insert(context.outputLines, line)
return true
end
end
print(line)
return true
end

function pathInfo(path)
expect(1, path, "string")
return buildPathInfo(path, 0)
end

function permissionInfo(path)
expect(1, path, "string")
local resolved = normalisePath(path)
local exists = fs.exists(resolved) == true
local isDir = exists == true and fs.isDir(resolved) or false
local entry = permissionEntryForPath(resolved, isDir)
local mode = parseModeValue(entry.mode) or (isDir == true and 755 or 644)
return {
path = resolved,
owner = entry.owner,
group = entry.group,
modeOctal = mode,
modeOctalString = string.format("%03d", mode),
permissions = permissionsFromMode(mode),
mode = toModeString(isDir, mode),
}
end

function requirePermission(path, operation)
expect(1, path, "string")
expect(2, operation, "string")
local resolved = normalisePath(path)
local info
if operation == "create" and fs.exists(resolved) ~= true then
local parent = fs.getDir(resolved)
if parent == nil or parent == "" then
parent = "/"
end
if fs.exists(parent) ~= true then
return false, "parent directory does not exist: " .. parent
end
info = buildPathInfo(parent, 0)
else
info = buildPathInfo(resolved, 0)
if info == nil then
return false, "path does not exist: " .. resolved
end
end
if isSystemOwner() == true then
return true
end
if info.readOnly == true and (operation == "write" or operation == "create" or operation == "delete" or operation == "own") then
return false, "access denied: " .. resolved
end
if operation == "own" then
return false, "permission denied: " .. resolved
end
local permissions = principalPermissions({
owner = info.owner,
group = info.group,
mode = info.modeOctal,
})
if operation == "read" and permissions.read ~= true then
return false, "permission denied: " .. resolved
elseif (operation == "write" or operation == "create" or operation == "delete") and permissions.write ~= true then
return false, "permission denied: " .. resolved
elseif operation == "execute" and permissions.execute ~= true then
return false, "permission denied: " .. resolved
end
return true
end

function chmod(path, mode)
expect(1, path, "string")
expect(2, mode, "string", "number")
local resolved = normalisePath(path)
local info = buildPathInfo(resolved, 0)
if info == nil then
return false, "path does not exist: " .. resolved
end
local parsedMode = parseModeValue(mode)
if parsedMode == nil then
return false, "invalid mode: " .. tostring(mode)
end
if isSystemOwner() ~= true and info.owner ~= currentUser() then
return false, "permission denied: " .. resolved
end
if info.readOnly == true then
return false, "access denied: " .. resolved
end
registerPathMetadata(resolved, info.isDir, {
owner = info.owner,
group = info.group,
mode = parsedMode,
})
return true
end

function chown(path, owner, group)
expect(1, path, "string")
expect(2, owner, "string")
expect(3, group, "string", "nil")
local resolved = normalisePath(path)
local info = buildPathInfo(resolved, 0)
if info == nil then
return false, "path does not exist: " .. resolved
end
local ok, reason = minux.validateUsername(owner)
if ok ~= true then
return false, reason
end
local targetGroup = group
if targetGroup == nil or targetGroup == "" then
targetGroup = defaultGroupForUser(owner)
end
if isSystemOwner() ~= true then
return false, "permission denied: " .. resolved
end
if info.readOnly == true then
return false, "access denied: " .. resolved
end
registerPathMetadata(resolved, info.isDir, {
owner = owner,
group = targetGroup,
mode = info.modeOctal,
})
return true
end

function touchPath(path)
expect(1, path, "string")
local resolved = normalisePath(path)
if fs.isDir(resolved) == true then
return false, "is a directory: " .. resolved
end
if fs.exists(resolved) == true then
return true
end
local parent = fs.getDir(resolved)
if parent ~= nil and parent ~= "" and fs.exists(parent) ~= true then
local ok, err = minux.makeDirectory(parent, true)
if ok ~= true then
return false, err
end
end
local ok, err = minux.requirePermission(resolved, "create")
if ok ~= true then
return false, err
end
local handle = fs.open(resolved, "w")
if handle == nil then
return false, "cannot create file: " .. resolved
end
handle.close()
registerPathMetadata(resolved, false)
return true
end

function listEntries(path, options)
expect(1, path, "string")
expect(2, options, "table", "nil")
local resolved = normalisePath(path)
if fs.exists(resolved) ~= true or fs.isDir(resolved) ~= true then
return false
end
local includeHidden = type(options) == "table" and options.includeHidden == true or false
local results = {}
for _, childName in ipairs(sortedChildren(resolved)) do
if includeHidden == true or isHiddenName(childName) ~= true then
table.insert(results, buildPathInfo(fs.combine(resolved, childName), 1))
end
end
return results
end

function findEntries(path, options)
expect(1, path, "string")
expect(2, options, "table", "nil")
local resolved = normalisePath(path)
if fs.exists(resolved) ~= true then
return false
end
local resolvedOptions = options or {}
if resolvedOptions.recursive == nil then
resolvedOptions.recursive = true
end
if resolvedOptions.includeHidden == nil then
resolvedOptions.includeHidden = true
end
local results = {}
walkEntries(resolved, resolvedOptions, results, 0)
return results
end

