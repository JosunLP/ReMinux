-- apt api's

local AptManager = {}
AptManager.__index = AptManager

local APT_ERROR_CONFIG_INVALID = 104
local APT_ERROR_PACKAGE_NOT_FOUND = 105
local APT_ERROR_SOURCE_UNAVAILABLE = 111
local VERSION_LESS = -1
local VERSION_EQUAL = 0
local VERSION_GREATER = 1

function AptManager.new()
return setmetatable({
installedListPath = "/etc/apt/list/installed.db",
sourceListPath = "/usr/apt/source.ls",
sourceCachePath = "/temp/apt/source.ls",
programListPath = "/temp/apt/programs.ls",
manifestDirectory = "/etc/apt/list/",
manifestCacheDirectory = "/temp/apt/manifest/",
mapCacheDirectory = "/temp/apt/map/",
githubRepo = "JosunLP/ReMinux",
githubDefaultRef = "main",
githubApiBase = "https://api.github.com/repos/JosunLP/ReMinux/",
repositoryManifestPath = "/etc/apt/manifest/APT.db",
releaseCachePath = "/temp/apt/github-release.db",
releaseCacheTtl = 3600,
releaseApiPerPage = 30,
releaseApiMaxPages = 5,
latestReleaseResolved = false,
latestReleaseTag = nil,
latestReleaseStatus = nil,
repositoryPackages = nil,
legacySources = {
"https://minux.cc/apt/2.0/soft/",
"https://minux.cc/apt/2.0/os/",
},
officialAptSources = {
"https://minux.cc/apt/2.0/soft/",
"https://minux.cc/apt/2.0/os/",
"https://minux.cc/beta/",
},
buildJobs = {
boot = {
sourceDir = "/etc/apt/boot/",
tempPath = "/temp/apt/addon.d",
targetPath = "/boot/addon.d",
label = "boot addon",
},
alias = {
sourceDir = "/etc/apt/alias/",
tempPath = "/etc/apt/build/build.tmp",
targetPath = "/boot/alias.ls",
label = "alias",
},
autorun = {
sourceDir = "/etc/apt/autorun/",
tempPath = "/etc/apt/build/autorun.tmp",
targetPath = "/boot/autorun.ls",
label = "autorun",
},
},
presetSources = {
stable = {
"https://minux.cc/apt/2.0/soft/",
"https://minux.cc/apt/2.0/os/",
},
beta = {
"https://minux.cc/beta/",
},
goldcube = {
"https://minux.cc/apt/2.0/soft/",
"https://minux.cc/apt/2.0/os/",
"https://goldcube.minux.cc/stable/",
},
},
}, AptManager)
end

function AptManager:ensureDirectory(path)
if path ~= nil and path ~= "" and fs.exists(path) == false then
fs.makeDir(path)
end
end

function AptManager:ensureParentDirectory(path)
local parent = fs.getDir(path)
if parent ~= nil and parent ~= "" then
self:ensureDirectory(parent)
end
end

function AptManager:deleteIfExists(path)
if fs.exists(path) then
fs.delete(path)
end
end

function AptManager:readLines(path)
local lines = {}
if fs.exists(path) == false then
return lines
end

local file = fs.open(path, "r")
if file == nil then
minux.debug("readLines:E:open failed:"..path, "apt")
return nil
end
local line = file.readLine()
while line ~= nil do
table.insert(lines, line)
line = file.readLine()
end
file.close()

return lines
end

function AptManager:writeLines(path, lines)
self:ensureParentDirectory(path)
self:deleteIfExists(path)

local file = fs.open(path, "w")
if file == nil then
minux.debug("writeLines:E:open failed: "..path, "apt")
return false
end
for index = 1, #lines do
file.writeLine(lines[index])
end
file.close()
return true
end

function AptManager:isPackageAccessAllowed(packname)
local isOwner = _G.owner == true or (_G.login ~= nil and _G.owner == _G.login)
return _G.admin == true or isOwner or packname == "auth-client"
end

function AptManager:isSourceAccessAllowed()
return _G.admin == true or (_G.login ~= nil and _G.owner == _G.login)
end

function AptManager:normalizeSource(source)
if source == nil or source == "" then
return source
end
if string.sub(source, -1) ~= "/" then
return source.."/"
end
return source
end

function AptManager:joinSourcePath(source, suffix)
return self:normalizeSource(source)..suffix
end

function AptManager:readRemoteText(url, headers)
if minux ~= nil and type(minux.hasHttpSupport) == "function" then
if minux.hasHttpSupport() ~= true then
return nil
end
elseif http == nil or http.get == nil or http.checkURL == nil then
return nil
end
if http.checkURL(url) ~= true then
return nil
end

local response = http.get(url, headers)
if response == nil then
return nil
end

local contents = response.readAll()
response.close()
if contents == nil or contents == "" then
return nil
end

return contents
end

function AptManager:getJsonDecoder()
if textutils ~= nil then
return textutils.unserialiseJSON or textutils.unserializeJSON
end
return nil
end

function AptManager:getCurrentEpochSeconds()
if os.epoch == nil then
return nil
end
return math.floor(os.epoch("utc") / 1000)
end

function AptManager:isReleaseTag(tag)
return type(tag) == "string" and (
string.match(tag, "^v?%d+%.%d+%.%d+$") ~= nil or
string.match(tag, "^v?%d+%.%d+%.%d+[-+][%w%._%-]+$") ~= nil
) 
end

function AptManager:isStableVersionTag(tag)
return type(tag) == "string" and string.match(tag, "^v?%d+%.%d+%.%d+$") ~= nil
end

function AptManager:isOfficialRef(ref)
return ref == self.githubDefaultRef or self:isReleaseTag(ref)
end

function AptManager:getRepositoryPackages()
if self.repositoryPackages ~= nil and fs.exists(self.repositoryManifestPath) then
return self.repositoryPackages
end

local packages = {}
if fs.exists(self.repositoryManifestPath) then
local lines = self:readLines(self.repositoryManifestPath)
if type(lines) ~= "table" then
minux.debug("repo manifest unreadable:"..self.repositoryManifestPath, "apt")
return packages
end
for index = 1, #lines do
local entry = lines[index]
if entry ~= "" and entry ~= "AIF" then
packages[entry] = true
end
end
else
packages["minux-main"] = true
end

if fs.exists(self.repositoryManifestPath) then
self.repositoryPackages = packages
end
return packages
end

function AptManager:isRepositoryPackage(packname)
return self:getRepositoryPackages()[packname] == true
end

function AptManager:readLatestReleaseCache()
local now = self:getCurrentEpochSeconds()
if now == nil or fs.exists(self.releaseCachePath) == false then
return false, nil, nil
end

local file = fs.open(self.releaseCachePath, "r")
if file == nil then
return false, nil, nil
end
local cachedAt = tonumber(file.readLine())
local cachedStatus = file.readLine()
local cachedTag = file.readLine()
file.close()
if cachedAt == nil then
return false, nil, nil
end
if now - cachedAt > self.releaseCacheTtl then
return false, nil, nil
end
-- Older cache files stored only two lines: [timestamp, tag-or-NONE].
if cachedTag == nil then
cachedTag = cachedStatus
if cachedTag == "NONE" then
cachedStatus = "none"
else
cachedStatus = "ok"
end
end
if cachedStatus == "none" then
return true, "none", nil
end
if cachedStatus == "ok" and self:isStableVersionTag(cachedTag) then
return true, "ok", cachedTag
end
return false, nil, nil
end

function AptManager:writeLatestReleaseCache(status, tag)
local now = self:getCurrentEpochSeconds()
if now == nil then
return
end
self:ensureParentDirectory(self.releaseCachePath)
local file = fs.open(self.releaseCachePath, "w")
file.writeLine(now)
file.writeLine(status)
file.writeLine(tag or "")
file.close()
end

function AptManager:parseVersion(version)
if type(version) ~= "string" then
return nil
end
local clean = string.gsub(version, "^v", "")
local major, minor, patch, suffix = string.match(clean, "^(%d+)%.(%d+)%.(%d+)(.*)$")
if major == nil then
return nil
end
if suffix == "" then
suffix = nil
else
local firstCharacter = string.sub(suffix, 1, 1)
if firstCharacter == "-" or firstCharacter == "+" or firstCharacter == "." then
suffix = string.sub(suffix, 2)
end
end
return {
major = tonumber(major),
minor = tonumber(minor),
patch = tonumber(patch),
suffix = suffix,
}
end

function AptManager:splitVersionSuffix(suffix)
local tokens = {}
local current = ""
local currentIsDigit = nil
local suffixValue = suffix or ""
local suffixLength = string.len(suffixValue)
for index = 1, suffixLength do
local char = string.sub(suffixValue, index, index)
if char == "." or char == "-" or char == "_" then
if current ~= "" then
table.insert(tokens, current)
current = ""
currentIsDigit = nil
end
else
local isDigit = string.match(char, "%d") ~= nil
if current ~= "" and currentIsDigit ~= isDigit then
table.insert(tokens, current)
current = char
else
current = current..char
end
currentIsDigit = isDigit
end
end
if current ~= "" then
table.insert(tokens, current)
end
return tokens
end

function AptManager:compareVersions(left, right)
if left == right then
return VERSION_EQUAL
end
local leftVersion = self:parseVersion(left)
local rightVersion = self:parseVersion(right)
if leftVersion == nil or rightVersion == nil then
return nil
end
if leftVersion.major ~= rightVersion.major then
return leftVersion.major > rightVersion.major and VERSION_GREATER or VERSION_LESS
end
if leftVersion.minor ~= rightVersion.minor then
return leftVersion.minor > rightVersion.minor and VERSION_GREATER or VERSION_LESS
end
if leftVersion.patch ~= rightVersion.patch then
return leftVersion.patch > rightVersion.patch and VERSION_GREATER or VERSION_LESS
end
if leftVersion.suffix == rightVersion.suffix then
return VERSION_EQUAL
elseif leftVersion.suffix == nil then
return VERSION_GREATER
elseif rightVersion.suffix == nil then
return VERSION_LESS
else
local leftTokens = self:splitVersionSuffix(leftVersion.suffix)
local rightTokens = self:splitVersionSuffix(rightVersion.suffix)
local maxTokens = math.max(#leftTokens, #rightTokens)
for index = 1, maxTokens do
local leftToken = leftTokens[index]
local rightToken = rightTokens[index]
if leftToken ~= rightToken then
if leftToken == nil then
return VERSION_LESS
elseif rightToken == nil then
return VERSION_GREATER
end
local leftNumber = tonumber(leftToken)
local rightNumber = tonumber(rightToken)
if leftNumber ~= nil and rightNumber ~= nil then
return leftNumber > rightNumber and VERSION_GREATER or VERSION_LESS
elseif leftNumber ~= nil then
return VERSION_LESS
elseif rightNumber ~= nil then
return VERSION_GREATER
elseif leftToken > rightToken then
return VERSION_GREATER
else
return VERSION_LESS
end
end
end
return VERSION_EQUAL
end
end

function AptManager:selectHighestReleaseTag(releases)
if type(releases) ~= "table" then
return nil
end
local bestTag = nil
for index = 1, #releases do
local release = releases[index]
local tag = release.tag_name
if type(release) == "table" and release.draft ~= true and release.prerelease ~= true and self:isStableVersionTag(tag) then
if bestTag == nil or self:compareVersions(tag, bestTag) == VERSION_GREATER then
bestTag = tag
end
end
end
return bestTag
end

function AptManager:fetchReleasePage(page)
local body = self:readRemoteText(self.githubApiBase.."releases?per_page="..self.releaseApiPerPage.."&page="..page, {
["User-Agent"] = "ReMinux",
Accept = "application/vnd.github+json",
})
if body == nil then
return nil, "error"
end

local decoder = self:getJsonDecoder()
if decoder == nil then
return nil, "error"
end

local ok, data = pcall(decoder, body)
if ok ~= true or type(data) ~= "table" then
return nil, "error"
end
return data, nil
end

function AptManager:getLatestReleaseTag()
if self.latestReleaseResolved == true then
return self.latestReleaseTag, self.latestReleaseStatus
end

local cacheFound, cachedStatus, cachedTag = self:readLatestReleaseCache()
if cacheFound == true then
self.latestReleaseResolved = true
self.latestReleaseStatus = cachedStatus
self.latestReleaseTag = cachedTag
return cachedTag, cachedStatus
end

self.latestReleaseStatus = "pending"
self.latestReleaseTag = nil
local bestTag = nil
for page = 1, self.releaseApiMaxPages do
local releases, pageError = self:fetchReleasePage(page)
if pageError ~= nil then
self.latestReleaseStatus = "error"
return nil, "error"
end
local pageBestTag = self:selectHighestReleaseTag(releases)
if pageBestTag ~= nil and (bestTag == nil or self:compareVersions(pageBestTag, bestTag) == VERSION_GREATER) then
bestTag = pageBestTag
end
if #releases < self.releaseApiPerPage then
break
end
end

if bestTag ~= nil then
self.latestReleaseResolved = true
self.latestReleaseStatus = "ok"
self.latestReleaseTag = bestTag
self:writeLatestReleaseCache("ok", bestTag)
return bestTag, "ok"
end

self.latestReleaseResolved = true
self.latestReleaseStatus = "none"
self.latestReleaseTag = nil
self:writeLatestReleaseCache("none", "")
return nil, "none"
end

function AptManager:getReMinuxSourceForRef(ref)
return "https://raw.githubusercontent.com/"..self.githubRepo.."/"..ref.."/etc/apt/"
end

function AptManager:getDefaultReMinuxSource()
local latestTag, latestStatus = self:getLatestReleaseTag()
if latestStatus == "ok" and latestTag ~= nil then
return self:getReMinuxSourceForRef(latestTag), "ok"
end
if latestStatus == "none" then
return self:getReMinuxSourceForRef(self.githubDefaultRef), "none"
end
return nil, latestStatus
end

function AptManager:dedupeSources(sources)
local unique = {}
local seen = {}
for index = 1, #sources do
local source = self:normalizeSource(sources[index])
if type(source) == "string" and source ~= "" and seen[source] ~= true then
seen[source] = true
table.insert(unique, source)
end
end
return unique
end

function AptManager:escapePattern(text)
return string.gsub(text, "([%(%)%.%%%+%-%*%?%[%]%^%$])", "%%%1")
end

function AptManager:parseOfficialSourceRef(source)
source = self:normalizeSource(source)
if type(source) ~= "string" or source == "" then
return nil
end
local ref = string.match(source, "^https://raw%.githubusercontent%.com/"..self:escapePattern(self.githubRepo).."/([^/]+)/etc/apt/?$")
if self:isOfficialRef(ref) then
return ref
end
return nil
end

function AptManager:getPackageSource(packname)
local packdb = self.manifestDirectory..packname..".db"
if fs.exists(packdb) ~= true then
return nil
end
local lineNumber = minux.findline(packdb, "https://")
if lineNumber ~= false and lineNumber ~= nil then
return self:normalizeSource(minux.printline(packdb, lineNumber))
end
return nil
end

function AptManager:isOfficialReMinuxSource(source)
source = self:normalizeSource(source)
if type(source) ~= "string" or source == "" then
return false
end
for index = 1, #self.officialAptSources do
if source == self:normalizeSource(self.officialAptSources[index]) then
return true
end
end
return self:parseOfficialSourceRef(source) ~= nil
end

function AptManager:isStableOfficialSource(source)
source = self:normalizeSource(source)
if type(source) ~= "string" or source == "" then
return false
end
for index = 1, #self.legacySources do
if source == self:normalizeSource(self.legacySources[index]) then
return true
end
end
local ref = self:parseOfficialSourceRef(source)
return ref == self.githubDefaultRef or self:isStableVersionTag(ref)
end

function AptManager:shouldPreferOfficialReleaseSource(sources, packageSource)
if #sources == 0 then
return packageSource == nil or self:isStableOfficialSource(packageSource)
end

local sawStableSource = false
for index = 1, #sources do
local source = self:normalizeSource(sources[index])
if type(source) == "string" and source ~= "" then
if self:isStableOfficialSource(source) then
sawStableSource = true
else
return false
end
end
end
if packageSource ~= nil then
if self:isStableOfficialSource(packageSource) ~= true then
return false
end
sawStableSource = true
end
return sawStableSource
end

function AptManager:getPreferredSources(packname, configuredSources, packageSource)
local preferred = {}
local useOfficialSource = false
if self:isRepositoryPackage(packname) == true then
useOfficialSource = self:shouldPreferOfficialReleaseSource(configuredSources, packageSource)
end
if useOfficialSource == true then
local officialSource = self:getDefaultReMinuxSource()
if officialSource ~= nil then
table.insert(preferred, officialSource)
end
end
for index = 1, #configuredSources do
table.insert(preferred, configuredSources[index])
end
if packageSource ~= nil then
table.insert(preferred, packageSource)
end
return self:dedupeSources(preferred)
end

function AptManager:getPresetSources(source)
if source == "default" then
source = "stable"
end

local copy = {}
if source == "stable" then
for index = 1, #self.legacySources do
table.insert(copy, self.legacySources[index])
end
return self:dedupeSources(copy)
end

local preset = self.presetSources[source]
if preset == nil then
return nil
end

for index = 1, #preset do
copy[index] = preset[index]
end
return self:dedupeSources(copy)
end

function AptManager:buildFromDirectory(job)
self:ensureDirectory(job.sourceDir)
self:ensureParentDirectory(job.tempPath)
self:ensureParentDirectory(job.targetPath)

minux.debug("clearing "..job.label.." build cache", "apt")
self:deleteIfExists(job.tempPath)

local buildFile = fs.open(job.tempPath, "w")
local entries = fs.list(job.sourceDir)
for index = 1, #entries do
local filename = entries[index]
minux.debug("reading:"..filename, "apt")
local sourceFile = fs.open(fs.combine(job.sourceDir, filename), "r")
buildFile.writeLine(sourceFile.readAll())
sourceFile.close()
end
buildFile.close()

minux.debug("file built, installing", "apt")
self:deleteIfExists(job.targetPath)
fs.move(job.tempPath, job.targetPath)
minux.debug("done", "apt")
return true
end

function AptManager:rebuildGeneratedFiles()
self:buildFromDirectory(self.buildJobs.boot)
self:buildFromDirectory(self.buildJobs.alias)
self:buildFromDirectory(self.buildJobs.autorun)
return true
end

function AptManager:findSources(packname)
local sources = self:readLines(self.sourceListPath)
if type(sources) ~= "table" then
minux.debug("source list unreadable:"..self.sourceListPath, "apt")
return nil, 104
end
for index = 1, #sources do
minux.debug("apt-source:"..sources[index], "apt")
end

local packageSource = self:getPackageSource(packname)
local packdb = self.manifestDirectory..packname..".db"
if fs.exists(packdb) then
minux.debug("package.db file found", "apt")
if packageSource ~= nil then
minux.debug("apt-source:"..packageSource, "apt")
end
end

sources = self:getPreferredSources(packname, sources, packageSource)
if #sources == 0 then
minux.debug("Error:102:", "apt")
return nil, 102
end

minux.debug("getpack:source:", "apt")
return sources
end

function AptManager:readRepositoryManifest(source)
local manifestUrl = self:joinSourcePath(source, "manifest/APT.db")
local contents = self:readRemoteText(manifestUrl)
if contents == nil or contents == "" then
return nil, "server unreachable"
end

return contents
end

function AptManager:getAvailablePackage(packname, cacheSuffix)
local sources, sourceError = self:findSources(packname)
if type(sources) ~= "table" then
return nil, nil, sourceError
end

self:ensureDirectory(self.manifestCacheDirectory)
local manifestCache = self.manifestCacheDirectory..packname.."."..(cacheSuffix or "info")..".db"
local sawReachableSource = false
local sourceUnavailable = false
for index = 1, #sources do
local source = sources[index]
local manifestUrl = self:joinSourcePath(source, "manifest/"..packname..".db")
fs.delete(manifestCache)
local downloaded = minux.download(manifestUrl, manifestCache)
if downloaded == true then
local line = minux.findline(manifestCache, "AIF=true")
if line ~= nil and line ~= false then
local version = apt.version(manifestCache)
fs.delete(manifestCache)
return source, version, nil
end
local _, repositoryError = self:readRepositoryManifest(source)
if repositoryError ~= nil then
sourceUnavailable = true
else
sawReachableSource = true
end
else
local _, repositoryError = self:readRepositoryManifest(source)
if repositoryError ~= nil then
sourceUnavailable = true
else
sawReachableSource = true
end
end
end

if fs.exists(manifestCache) then
fs.delete(manifestCache)
end
if sawReachableSource == true then
return nil, nil, nil
end
if sourceUnavailable == true then
return nil, nil, APT_ERROR_SOURCE_UNAVAILABLE
end
return nil, nil, nil
end

function AptManager:appendSource(source)
source = self:normalizeSource(source)
local sources = self:readLines(self.sourceListPath)
if type(sources) ~= "table" then
return false
end
table.insert(sources, source)
return self:writeLines(self.sourceListPath, self:dedupeSources(sources))
end

function AptManager:removeSource(source)
source = self:normalizeSource(source)
local sources = self:readLines(self.sourceListPath)
if type(sources) ~= "table" then
return false
end
local updated = {}
local removed = false

for index = 1, #sources do
local nextSource = self:normalizeSource(sources[index])
if removed == false and nextSource == source then
removed = true
else
table.insert(updated, sources[index])
end
end

if removed == true then
return self:writeLines(self.sourceListPath, updated)
end

return false
end

local manager = AptManager.new()

function verifyconfig()
local repairedConfig = false
local repairFailed = false

if fs.exists(manager.installedListPath) == false then
minux.debug("ERROR:104:Installed.db missing or corrupt", "apt")
if not manager:writeLines(manager.installedListPath, { "minux-main" }) then
minux.debug("ERROR:104:Installed.db repair failed", "apt")
repairFailed = true
else
repairedConfig = true
end
end

if fs.exists(manager.sourceListPath) ~= true then
minux.debug("ERROR:104:source missing or corrupt", "apt")
if not manager:writeLines(manager.sourceListPath, manager:getPresetSources("stable")) then
minux.debug("ERROR:104:source repair failed", "apt")
repairFailed = true
else
repairedConfig = true
end
end

if repairFailed == true then
return nil
end

if repairedConfig == true then
return true
end

return false
end

function rebuildgenerated()
return manager:rebuildGeneratedFiles()
end

function install(packname)
expect(1, packname, "string")
if manager:isPackageAccessAllowed(packname) ~= true then
minux.debug("APT:Access denied", "apt")
return 100
end
local configStatus = verifyconfig()
if configStatus == nil then
return APT_ERROR_CONFIG_INVALID
end
if configStatus == true then
minux.debug("apt:install file was rebuilt!", "apt")
end
minux.debug("apt:checking:"..packname, "apt")
if apt.checkinstall(packname) == true then
minux.debug("apt:pack already installed", "apt")
return true
end

minux.debug("install:running getpack", "apt")
local result = apt.getpack(packname)
if result == true then
if fs.exists(manager.manifestDirectory..packname..".db") == true then
minux.insertline(manager.installedListPath, packname)
apt.rebuildgenerated()
minux.debug("install:updated installed.db", "apt")
return true
end

minux.debug("getpack:E:105:pack:"..packname, "apt")
return 105
elseif type(result) == "number" then
return result
end

return false
end

function findsource(packname)
expect(1, packname, "string")
return manager:findSources(packname)
end

function getpack(packname)
expect(1, packname, "string")
if manager:isPackageAccessAllowed(packname) ~= true then
minux.debug("APT:Access denied", "apt")
return 100
end

local sources, sourceError = manager:findSources(packname)
if sources == nil then
return sourceError
end

local manifestPath = manager.manifestDirectory..packname..".db"
local packageSource = nil
minux.debug("start search for pack", "apt")
for index = 1, #sources do
local source = sources[index]
local manifestUrl = manager:joinSourcePath(source, "manifest/"..packname..".db")
minux.debug("trying "..manifestUrl, "apt")
fs.delete(manifestPath)
local downloaded = minux.download(manifestUrl, manifestPath)
if downloaded == true then
local temp = fs.open(manifestPath, "r")
local manifestState = temp.readLine()
temp.close()
if manifestState == "AIF=true" then
packageSource = source
minux.debug("getpack:Pack found:"..packname, "apt")
minux.debug("getpack:source:"..packageSource, "apt")
break
end
minux.debug("getpack:pack not found", "apt")
minux.debug("not on this server", "apt")
else
minux.debug("packfile not found on server", "apt")
end
end

if packageSource == nil then
minux.debug("E:105:Notfound", "apt")
return 105
end

local dependenciesComplete = true
minux.debug("checking for dependencies", "apt")
local manifest = minux.readtable(manifestPath)
local manifestIndex = 1
local dependenciesStarted = false
local fileListStarted = false
local keyfile = false
while manifest[manifestIndex] ~= nil do
local entry = manifest[manifestIndex]
if entry == "[depstart]" then
dependenciesStarted = true
elseif entry == "[depstop]" then
dependenciesStarted = false
elseif dependenciesStarted == true then
minux.debug("dep:installing:"..entry, "apt")
local dependencyResult = apt.install(entry)
if dependencyResult ~= true then
minux.debug("dep:E:103:failed:"..entry, "apt")
dependenciesComplete = false
end
elseif entry == "[filelist]" then
fileListStarted = true
elseif fileListStarted == true and keyfile == false then
keyfile = entry
minux.debug("apt:keyfile:"..keyfile, "apt")
end
manifestIndex = manifestIndex + 1
end

if dependenciesComplete ~= true then
minux.debug("getpack:E:103:dependencies not met", "apt")
return 103
end

if keyfile ~= false then
fs.delete(keyfile)
end

manager:ensureDirectory(manager.mapCacheDirectory)
local downloadSource = manager:joinSourcePath(packageSource, "repository/"..packname..".map")
local isPhp = minux.findline(manifestPath, "php=true")
if isPhp ~= false and isPhp ~= nil then
downloadSource = packageSource.."repository/map.php?id="..packname.."&type=map&clean=true"
end

local mapPath = manager.mapCacheDirectory..packname..".map"
fs.delete(mapPath)
minux.download(downloadSource, mapPath)
if fs.exists(mapPath) == true then
local originalTerminal = minux.disableoutput()
shell.run(mapPath.." /")
fs.delete(mapPath)
minux.enableoutput(originalTerminal)
minux.debug("getpack:package executed.", "apt")
if minux.getconfig("mapcleanup") == "enabled" and fs.exists(mapPath) then
fs.delete(mapPath)
end
else
minux.debug("getpack:nopack-dlfail:109", "apt")
return 109
end

if keyfile ~= false and fs.exists(keyfile) == false then
minux.debug("getpack:E110:keyfile check failed", "apt")
return 110
end

manager.repositoryPackages = nil
minux.debug("getpack:ending", "apt")
return true
end

-- Only uninstall canonical absolute file paths from package manifests.
-- This avoids deleting relative traversal targets or malformed section data.
local function isValidManifestFilePath(path)
if type(path) ~= "string" or path == "" or path == "/" then return false end
if string.sub(path, 1, 1) ~= "/" then return false end
if string.find(path, "..", 1, true) ~= nil then return false end
local normalized = fs.combine("/", path)
if string.sub(normalized, 1, 1) ~= "/" then
normalized = "/"..normalized
end
return normalized == path
end

function uninstall(packname)
expect(1, packname, "string")
minux.debug("removing pack:"..packname, "apt")
verifyconfig()
if manager:isPackageAccessAllowed(packname) ~= true then
minux.debug("APT:Access denied", "apt")
return false
elseif packname == "minux-main" then
return false
elseif apt.checkinstall(packname) == false then
minux.debug("ERROR:106", "apt")
return true
end

minux.debug("running cleanup:"..packname, "apt")
apt.cleanup(packname)
minux.debug("clearing manifest filelist", "apt")
local manifestFile = manager.manifestDirectory..packname..".db"
local temp = fs.open(manifestFile, "r")
if temp == nil then
minux.debug("uninstall:E:104:manifest unreadable:"..manifestFile, "apt")
return false
end
local listStart = false
local data = temp.readLine()
while data ~= nil do
if data == "[filelist]" then
listStart = true
data = temp.readLine()
end
if listStart == true and data ~= nil and isValidManifestFilePath(data) then
fs.delete(data)
elseif listStart == true and data ~= nil and string.sub(data, 1, 1) == "[" then
listStart = false
end
data = temp.readLine()
end
temp.close()

minux.debug("clearing package manifest", "apt")
fs.delete(manifestFile)
minux.debug("updating configuration", "apt")
minux.removestring(manager.installedListPath, packname)
apt.rebuildgenerated()
manager.repositoryPackages = nil
minux.debug("Finished", "apt")
return true
end

function AptManager:shouldUpdatePackage(installedVersion, availableVersion, forcedupdate)
if forcedupdate == true then
return true
end
if availableVersion == nil then
return false
end
if installedVersion == nil then
return true
end
local comparison = self:compareVersions(availableVersion, installedVersion)
if comparison ~= nil then
return comparison == VERSION_GREATER
end
return availableVersion ~= installedVersion
end

function update(packname)
expect(1, packname, "string", "nil")
if verifyconfig() == nil then
return APT_ERROR_CONFIG_INVALID
end

local forcedupdate = packname == "-f"
if packname ~= nil and forcedupdate ~= true then
if apt.checkinstall(packname) ~= true then
return false
end
minux.debug("update:updating:"..packname, "apt")
local installedVersion = nil
local manifestPath = manager.manifestDirectory..packname..".db"
if fs.exists(manifestPath) then
installedVersion = apt.version(manifestPath)
end
local _, availableVersion, sourceError = manager:getAvailablePackage(packname, "single")
if sourceError ~= nil then
return sourceError
end
if availableVersion == nil then
return APT_ERROR_PACKAGE_NOT_FOUND
end
if manager:shouldUpdatePackage(installedVersion, availableVersion, false) ~= true then
return true
end
local updateResult = apt.getpack(packname)
if updateResult == true then
apt.rebuildgenerated()
return true
end
return updateResult
end

minux.debug("reading installed.db", "apt")
local installedPackages = manager:readLines(manager.installedListPath)
if type(installedPackages) ~= "table" then
minux.debug("update:installed list unreadable:"..manager.installedListPath, "apt")
return false
end
local updateFailed = false
for index = 1, #installedPackages do
local nextpack = installedPackages[index]
minux.debug("finding source", "apt")
local installedVersion = nil
local manifestPath = manager.manifestDirectory..nextpack..".db"
if fs.exists(manifestPath) then
installedVersion = apt.version(manifestPath)
end
local _, availableVersion, sourceError = manager:getAvailablePackage(nextpack, "update")
if sourceError ~= nil then
minux.debug("update:source lookup failed:"..nextpack..":"..tostring(sourceError), "apt")
updateFailed = true
elseif availableVersion == nil then
minux.debug("update:package manifest unavailable:"..nextpack, "apt")
updateFailed = true
else
local packageNeedsUpdate = manager:shouldUpdatePackage(installedVersion, availableVersion, forcedupdate)
if packageNeedsUpdate == true then
minux.debug("updating pack:", "apt")
local updateResult = apt.getpack(nextpack)
if updateResult ~= true then
minux.debug("update:package update failed:"..nextpack..":"..tostring(updateResult), "apt")
updateFailed = true
end
else
minux.debug("update:package already current or newer:"..nextpack, "apt")
end
end
end

minux.debug("updating configuration", "apt")
if apt.rebuildgenerated() ~= true then
return false
end
if updateFailed == true then
return false
end
return true
end

function packageinfo(packname)
expect(1, packname, "string", "nil")
if packname == nil then
packname = "minux-main"
end

local info = {
package = packname,
installed = apt.checkinstall(packname),
installedVersion = nil,
availableVersion = nil,
source = nil,
releaseTag = nil,
releaseStatus = "disabled",
releaseTracking = false,
repositoryPackage = manager:isRepositoryPackage(packname),
}

local configStatus = verifyconfig()
if configStatus == nil then
info.error = APT_ERROR_CONFIG_INVALID
return info
end

local installedManifest = manager.manifestDirectory..packname..".db"
if fs.exists(installedManifest) then
info.installedVersion = apt.version(installedManifest)
end

local configuredSources = manager:readLines(manager.sourceListPath)
if type(configuredSources) ~= "table" then
configuredSources = {}
end
local packageSource = manager:getPackageSource(packname)
if info.repositoryPackage == true and manager:shouldPreferOfficialReleaseSource(configuredSources, packageSource) == true then
info.releaseTracking = true
local latestTag, latestStatus = manager:getLatestReleaseTag()
info.releaseStatus = latestStatus or "error"
if latestStatus == "ok" then
info.releaseTag = latestTag
end
end
local source, availableVersion, sourceError = manager:getAvailablePackage(packname, "info")
if sourceError ~= nil then
info.error = sourceError
return info
end
if source == nil or availableVersion == nil then
info.error = APT_ERROR_PACKAGE_NOT_FOUND
return info
end
info.source = source
info.availableVersion = availableVersion

return info
end

function version(dbfile)
expect(1, dbfile, "string")
if fs.exists(dbfile) then
local result = minux.findline(dbfile, "version=")
if result ~= nil and result ~= false then
local lineData = minux.printline(dbfile, result)
result = string.sub(lineData, 9)
end
return result
end

return false
end

